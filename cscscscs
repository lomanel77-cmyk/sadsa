// ===================== MOUSE DELAY FIX =====================
// Disables Windows "Enhance pointer precision" (mouse acceleration) WITHOUT
// touching mouse speed. Speed = 10 is the neutral sensitivity value, but
// writing it blindly changes the feel / effective DPI for users that run
// anywhere else - so we leave SPI_MOUSESPEED alone entirely. We also only
// apply the fix while Minecraft is the foreground window, and restore it the
// instant the user alt-tabs out, so desktop / other apps keep their normal
// pointer behavior.
static bool g_mouseFixApplied = false;
static int  g_savedMouseParams[3] = { 6, 10, 1 };

static void ApplyMouseDelayFix() {
    if (g_mouseFixApplied) return;
    int cur[3] = { 0, 0, 0 };
    if (SystemParametersInfoA(SPI_GETMOUSE, 0, cur, 0)) {
        g_savedMouseParams[0] = cur[0];
        g_savedMouseParams[1] = cur[1];
        g_savedMouseParams[2] = cur[2];
    }
    // threshold1, threshold2, acceleration flag. All zero = "Enhance pointer
    // precision" fully disabled. Speed is intentionally left untouched so the
    // user's DPI / sensitivity feel is preserved.
    int noAccel[3] = { 0, 0, 0 };
    SystemParametersInfoA(SPI_SETMOUSE, 0, noAccel, SPIF_SENDCHANGE);
    g_mouseFixApplied = true;
    Log("Mouse delay fix: applied (accel OFF, speed untouched)");
}

static void RestoreMouseDelayFix() {
    if (!g_mouseFixApplied) return;
    SystemParametersInfoA(SPI_SETMOUSE, 0, g_savedMouseParams, SPIF_SENDCHANGE);
    g_mouseFixApplied = false;
    Log("Mouse delay fix: restored");
}

// ===================== OPENGL HOOK FOR ESP =====================
typedef BOOL(WINAPI* twglSwapBuffers)(HDC hDc);
twglSwapBuffers oWglSwapBuffers = nullptr;

static const int MAX_STOLEN = 32;
static int g_stolenBytes = 0;
static BYTE g_originalBytes[MAX_STOLEN] = {};
static BYTE* g_trampoline = nullptr;
static bool g_hookInstalled = false;
static void* g_pOriginalWglSwapBuffers = nullptr;

static int x64_modrm_extra(const BYTE* p) {
    BYTE modrm = *p; BYTE mod = (modrm >> 6) & 3; BYTE rm = modrm & 7; int extra = 0;
    if (mod == 3) return 1; bool hasSIB = (rm == 4); extra = 1;
    if (hasSIB) { extra++; rm = p[1] & 7; }
    if (mod == 0) { if (rm == 5) extra += 4; }
    else if (mod == 1) extra += 1; else if (mod == 2) extra += 4;
    return extra;
}

static int x64_insn_len(const BYTE* code) {
    const BYTE* p = code;
    for (;;) { if (*p == 0x66 || *p == 0x67 || *p == 0xF2 || *p == 0xF3 || *p == 0x2E || *p == 0x3E || *p == 0x26 || *p == 0x36 || *p == 0x64 || *p == 0x65) { p++; continue; } break; }
    bool rex_w = false; if (*p >= 0x40 && *p <= 0x4F) { rex_w = (*p & 0x08) != 0; p++; }
    BYTE op = *p++;
    if (op >= 0x50 && op <= 0x5F) return (int)(p - code); if (op == 0x90) return (int)(p - code);
    if (op == 0xC3) return (int)(p - code); if (op == 0xCC) return (int)(p - code);
    if (op == 0xEB) return (int)(p - code) + 1; if (op == 0xE9) return (int)(p - code) + 4; if (op == 0xE8) return (int)(p - code) + 4;
    if (op >= 0x70 && op <= 0x7F) return (int)(p - code) + 1;
    if (op >= 0xB8 && op <= 0xBF) return (int)(p - code) + (rex_w ? 8 : 4);
    if (op >= 0xB0 && op <= 0xB7) return (int)(p - code) + 1;
    if (op == 0x0F) { BYTE op2 = *p++; if (op2 >= 0x80 && op2 <= 0x8F) return (int)(p - code) + 4; if (op2 == 0x1F) return (int)(p - code) + x64_modrm_extra(p); return 0; }
    if (op == 0x89 || op == 0x8B || op == 0x8D || op == 0x01 || op == 0x03 || op == 0x85 || op == 0x87 || op == 0x39 || op == 0x3B) return (int)(p - code) + x64_modrm_extra(p);
    if (op == 0xFF) return (int)(p - code) + x64_modrm_extra(p);
    if (op == 0x80 || op == 0x83) return (int)(p - code) + x64_modrm_extra(p) + 1;
    if (op == 0x81) return (int)(p - code) + x64_modrm_extra(p) + 4;
    if (op == 0xC6) return (int)(p - code) + x64_modrm_extra(p) + 1;
    if (op == 0xC7) return (int)(p - code) + x64_modrm_extra(p) + 4;
    if (op == 0xF6) { BYTE reg = (p[0] >> 3) & 7; return (int)(p - code) + x64_modrm_extra(p) + (reg == 0 ? 1 : 0); }
    if (op == 0xF7) { BYTE reg = (p[0] >> 3) & 7; return (int)(p - code) + x64_modrm_extra(p) + (reg == 0 ? 4 : 0); }
    if (op == 0xC2) return (int)(p - code) + 2;
    return 0;
}

static BYTE* AllocateNear(void* target, size_t size) {
    uintptr_t tgt = (uintptr_t)target;
    for (uintptr_t delta = 0x10000; delta < 0x40000000ULL; delta += 0x10000) {
        if (tgt > delta) { BYTE* p = (BYTE*)VirtualAlloc((void*)(tgt - delta), size, MEM_COMMIT | MEM_RESERVE, PAGE_EXECUTE_READWRITE); if (p) return p; }
        BYTE* p = (BYTE*)VirtualAlloc((void*)(tgt + delta), size, MEM_COMMIT | MEM_RESERVE, PAGE_EXECUTE_READWRITE); if (p) return p;
    }
    return (BYTE*)VirtualAlloc(nullptr, size, MEM_COMMIT | MEM_RESERVE, PAGE_EXECUTE_READWRITE);
}

static void FixupRipRelative(BYTE* trampoline, BYTE* original, int stolenBytes) {
    int pos = 0;
    while (pos < stolenBytes) {
        int len = x64_insn_len(trampoline + pos); if (len <= 0) break;
        BYTE* insn = trampoline + pos; BYTE* pp = insn; int pi = 0;
        while (pi < len && (pp[pi] == 0x66 || pp[pi] == 0x67 || pp[pi] == 0xF2 || pp[pi] == 0xF3)) pi++;
        if (pi < len && pp[pi] >= 0x40 && pp[pi] <= 0x4F) pi++;
        if (pi < len && (pp[pi] == 0xE8 || pp[pi] == 0xE9)) {
            int relIdx = pi + 1; if (relIdx + 4 <= len) {
                int32_t oldRel; memcpy(&oldRel, insn + relIdx, 4);
                intptr_t targetAddr = (intptr_t)(original + pos + len) + oldRel;
                intptr_t newRIP = (intptr_t)(trampoline + pos + len);
                int64_t newRel64 = targetAddr - newRIP;
                if (newRel64 >= INT32_MIN && newRel64 <= INT32_MAX) { int32_t newRel = (int32_t)newRel64; memcpy(insn + relIdx, &newRel, 4); }
            }
        }
        pos += len;
    }
}

static bool InstallHook(void* target, void* hook, void** original) {
    const int MIN_HOOK = 12; BYTE* t = (BYTE*)target;
    if (t[0] == 0xFF && t[1] == 0x25) { int32_t disp = *(int32_t*)(t + 2); void** jmpTarget = (void**)(t + 6 + disp); target = *jmpTarget; t = (BYTE*)target; }
    else if (t[0] == 0x48 && t[1] == 0xFF && t[2] == 0x25) { int32_t disp = *(int32_t*)(t + 3); void** jmpTarget = (void**)(t + 7 + disp); target = *jmpTarget; t = (BYTE*)target; }
    else if (t[0] == 0xE9) { int32_t disp = *(int32_t*)(t + 1); void* jmpDest = (void*)(t + 5 + disp); target = jmpDest; t = (BYTE*)target; }

    g_stolenBytes = 0; int pos = 0;
    while (pos < MIN_HOOK) { int len = x64_insn_len(t + pos); if (len == 0) return false; pos += len; }
    g_stolenBytes = pos; if (g_stolenBytes > MAX_STOLEN) return false;
    memcpy(g_originalBytes, t, g_stolenBytes);

    g_trampoline = AllocateNear(target, g_stolenBytes + 16); if (!g_trampoline) return false;
    memcpy(g_trampoline, t, g_stolenBytes); FixupRipRelative(g_trampoline, t, g_stolenBytes);

    BYTE* trampolineJmp = g_trampoline + g_stolenBytes;
    uintptr_t returnAddr = (uintptr_t)target + g_stolenBytes;
    uint32_t lo32 = (uint32_t)(returnAddr & 0xFFFFFFFF); uint32_t hi32 = (uint32_t)(returnAddr >> 32);
    trampolineJmp[0] = 0x68; memcpy(trampolineJmp + 1, &lo32, 4);
    trampolineJmp[5] = 0xC7; trampolineJmp[6] = 0x44; trampolineJmp[7] = 0x24; trampolineJmp[8] = 0x04;
    memcpy(trampolineJmp + 9, &hi32, 4); trampolineJmp[13] = 0xC3;

    *original = (void*)g_trampoline;
    DWORD oldProtect;
    if (!VirtualProtect(target, g_stolenBytes, PAGE_EXECUTE_READWRITE, &oldProtect)) return false;
    BYTE* tb = (BYTE*)target; tb[0] = 0x48; tb[1] = 0xB8; uintptr_t hookAddr = (uintptr_t)hook; memcpy(tb + 2, &hookAddr, 8); tb[10] = 0xFF; tb[11] = 0xE0;
    for (int i = 12; i < g_stolenBytes; i++) tb[i] = 0x90;
    VirtualProtect(target, g_stolenBytes, oldProtect, &oldProtect);
    FlushInstructionCache(GetCurrentProcess(), target, g_stolenBytes);

    g_pOriginalWglSwapBuffers = target; g_hookInstalled = true;
    return true;
}

static void RemoveHook(void* target) {
    if (!g_hookInstalled || !target) return;
    DWORD oldProtect;
    if (VirtualProtect(target, g_stolenBytes, PAGE_EXECUTE_READWRITE, &oldProtect)) {
        memcpy(target, g_originalBytes, g_stolenBytes);
        VirtualProtect(target, g_stolenBytes, oldProtect, &oldProtect);
        FlushInstructionCache(GetCurrentProcess(), target, g_stolenBytes);
    }
    if (g_trampoline) { VirtualFree(g_trampoline, 0, MEM_RELEASE); g_trampoline = nullptr; }
    g_hookInstalled = false;
}

#define GL_FONT_COUNT 18
static const int GL_FONT_SIZES[GL_FONT_COUNT] = { 12,14,16,18,20,22,24,27,30,34,38,42,48,54,60,68,78,90 };
static GLuint g_fontLists[GL_FONT_COUNT] = {};
static GLuint g_fontListsNormal[GL_FONT_COUNT] = {};
static bool g_fontInit = false;

static int PickFontIndex(int desiredSize) {
    int bestIdx = 1, bestDiff = 999;
    for (int i = 0; i < GL_FONT_COUNT; i++) {
        int d = GL_FONT_SIZES[i] - desiredSize;
        int penalty = d >= 0 ? (int)(d * 0.85f) : -d;
        if (penalty < bestDiff) { bestDiff = penalty; bestIdx = i; }
    }
    return bestIdx;
}

static void InitGLFonts(HDC hDc) {
    if (g_fontInit) return;
    for (int i = 0; i < GL_FONT_COUNT; i++) {
        g_fontLists[i] = glGenLists(96);
        g_fontListsNormal[i] = glGenLists(96);
        HFONT hFontBold = CreateFontA(GL_FONT_SIZES[i], 0, 0, 0, FW_SEMIBOLD, FALSE, FALSE, FALSE,
            DEFAULT_CHARSET, OUT_TT_ONLY_PRECIS, CLIP_DEFAULT_PRECIS, CLEARTYPE_QUALITY, VARIABLE_PITCH | FF_SWISS, "Segoe UI");
        HFONT hFontNorm = CreateFontA(GL_FONT_SIZES[i], 0, 0, 0, FW_NORMAL, FALSE, FALSE, FALSE,
            DEFAULT_CHARSET, OUT_TT_ONLY_PRECIS, CLIP_DEFAULT_PRECIS, CLEARTYPE_QUALITY, VARIABLE_PITCH | FF_SWISS, "Segoe UI");
        HFONT oldFont = (HFONT)SelectObject(hDc, hFontBold);
        wglUseFontBitmaps(hDc, 32, 96, g_fontLists[i]);
        SelectObject(hDc, hFontNorm);
        wglUseFontBitmaps(hDc, 32, 96, g_fontListsNormal[i]);
        SelectObject(hDc, oldFont);
        DeleteObject(hFontBold); DeleteObject(hFontNorm);
    }
    g_fontInit = true;
}

static void DrawESPTextSized(float x, float y, const char* text, int r, int g, int b, int fontSize) {
    if (!g_fontInit) return;
    int idx = PickFontIndex(fontSize);
    GLsizei len = (GLsizei)strlen(text);
    glListBase(g_fontLists[idx] - 32);
    glColor4ub(0, 0, 0, 230);
    glRasterPos2f(x - 1, y); glCallLists(len, GL_UNSIGNED_BYTE, text);
    glRasterPos2f(x + 1, y); glCallLists(len, GL_UNSIGNED_BYTE, text);
    glRasterPos2f(x, y - 1); glCallLists(len, GL_UNSIGNED_BYTE, text);
    glRasterPos2f(x, y + 1); glCallLists(len, GL_UNSIGNED_BYTE, text);
    glColor3ub(r, g, b);
    glRasterPos2f(x, y);
    glCallLists(len, GL_UNSIGNED_BYTE, text);
}

static bool GL_WorldToScreenMat(const Vec3& world, POINT& out, int sw, int sh, const Vec3& rp, const float mv[16], const float proj[16]) {
    float rx = (float)(world.x - rp.x), ry = (float)(world.y - rp.y), rz = (float)(world.z - rp.z);
    float ex = mv[0]*rx + mv[4]*ry + mv[8]*rz + mv[12];
    float ey = mv[1]*rx + mv[5]*ry + mv[9]*rz + mv[13];
    float ez = mv[2]*rx + mv[6]*ry + mv[10]*rz + mv[14];
    float ew = mv[3]*rx + mv[7]*ry + mv[11]*rz + mv[15];
    float cx = proj[0]*ex + proj[4]*ey + proj[8]*ez + proj[12]*ew;
    float cy = proj[1]*ex + proj[5]*ey + proj[9]*ez + proj[13]*ew;
    float cw = proj[3]*ex + proj[7]*ey + proj[11]*ez + proj[15]*ew;
    if (cw <= 0.01f) return false;
    float ndcX = cx / cw, ndcY = cy / cw;
    out.x = (LONG)((ndcX + 1.0f) * 0.5f * sw);
    out.y = (LONG)((1.0f - ndcY) * 0.5f * sh);
    return (out.x >= -500 && out.x <= sw + 500 && out.y >= -500 && out.y <= sh + 500);
}

static bool GL_ManualWorldToScreen(const Vec3& world, POINT& out, int sw, int sh, const Vec3& cam, const Rotation& rot, float fov) {
    double dx = world.x - cam.x, dy = world.y - cam.y, dz = world.z - cam.z;
    double yawRad = (rot.yaw + 180.0) * (KARVIS_PI / 180.0);
    double pitchRad = rot.pitch * (KARVIS_PI / 180.0);
    double cosy = cos(yawRad), siny = sin(yawRad);
    double cosp = cos(pitchRad), sinp = sin(pitchRad);
    double x2 = dx * cosy + dz * siny;
    double z2 = -dx * siny + dz * cosy;
    double y2 = dy * cosp - z2 * sinp;
    double zz = dy * sinp + z2 * cosp;
    if (zz >= -0.1) return false;
    double depth = -zz;
    double fovRad = (fov * 0.5) * (KARVIS_PI / 180.0);
    double focal = (sh * 0.5) / tan(fovRad);
    out.x = (LONG)(sw * 0.5 + (x2 * focal / depth));
    out.y = (LONG)(sh * 0.5 - (y2 * focal / depth));
    return (out.x >= -500 && out.x <= sw + 500 && out.y >= -500 && out.y <= sh + 500);
}

static void DrawESPEntities(int w, int h) {
    std::vector<EspEntityData> ents; EspCameraData cam;
    EnterCriticalSection(&g_espCS);
    ents = g_espEntities; cam = g_espCam;
    LeaveCriticalSection(&g_espCS);
    if (ents.empty() || !cam.valid) return;

    for (const auto& e : ents) {
        Vec3 feet = { e.x, e.y - 0.05f, e.z };
        Vec3 head = feet; head.y += e.height + 0.2f;

        POINT sFeet, sHead;
        bool feetOK = false, headOK = false;

        if (cam.matricesValid) {
            feetOK = GL_WorldToScreenMat(feet, sFeet, w, h, cam.renderPos, cam.mvMatrix, cam.projMatrix);
            headOK = GL_WorldToScreenMat(head, sHead, w, h, cam.renderPos, cam.mvMatrix, cam.projMatrix);
        }
        if (!feetOK) feetOK = GL_ManualWorldToScreen(feet, sFeet, w, h, cam.camPos, cam.camRot, cam.camFov);
        if (!headOK) headOK = GL_ManualWorldToScreen(head, sHead, w, h, cam.camPos, cam.camRot, cam.camFov);

        if (!headOK) continue;

        int boxH = feetOK ? (sFeet.y - sHead.y) : 30;
        if (boxH < 6) boxH = 6;
        if (boxH > h * 3) boxH = (int)(h * 0.5f);
        int boxW = (int)(boxH * 0.55f);
        if (boxW < 8) boxW = 8;
        int centerX = feetOK ? (sFeet.x + sHead.x) / 2 : sHead.x;
        int by = sHead.y;
        int bx = centerX - boxW / 2;

        glLineWidth(2.0f);
        glBegin(GL_LINE_LOOP);
        glColor3ub(0, 180, 255);
        glVertex2f((float)bx, (float)by);
        glVertex2f((float)(bx + boxW), (float)by);
        glVertex2f((float)(bx + boxW), (float)(by + boxH));
        glVertex2f((float)bx, (float)(by + boxH));
        glEnd();

        glLineWidth(3.0f);
        glBegin(GL_LINE_LOOP);
        glColor4ub(0, 0, 0, 180);
        glVertex2f((float)(bx - 1), (float)(by - 1));
        glVertex2f((float)(bx + boxW + 1), (float)(by - 1));
        glVertex2f((float)(bx + boxW + 1), (float)(by + boxH + 1));
        glVertex2f((float)(bx - 1), (float)(by + boxH + 1));
        glEnd();
        glLineWidth(1.5f);
        glBegin(GL_LINE_LOOP);
        glColor3ub(0, 180, 255);
        glVertex2f((float)bx, (float)by);
        glVertex2f((float)(bx + boxW), (float)by);
        glVertex2f((float)(bx + boxW), (float)(by + boxH));
        glVertex2f((float)bx, (float)(by + boxH));
        glEnd();

        {
            float hf = e.maxHealth > 0.0f ? e.health / e.maxHealth : 0.0f;
            bool hasAbsorption = e.health > e.maxHealth;
            float absPct = 0.0f;
            if (hasAbsorption) {
                absPct = std::min(1.0f, (e.health - e.maxHealth) / e.maxHealth);
                hf = 1.0f;
            }
            hf = std::max(0.0f, std::min(1.0f, hf));

            int barX = bx - 6;
            int fillH = (int)((boxH - 2) * hf);
            int absFillH = hasAbsorption ? (int)((boxH - 2) * absPct) : 0;

            glBegin(GL_QUADS); glColor4ub(0, 0, 0, 255);
            glVertex2f((float)barX, (float)by); glVertex2f((float)(barX + 4), (float)by);
            glVertex2f((float)(barX + 4), (float)(by + boxH)); glVertex2f((float)barX, (float)(by + boxH));
            glEnd();

            int gr = hf > 0.7f ? 0 : (hf > 0.3f ? 255 : 255);
            int gg = hf > 0.7f ? 220 : (hf > 0.3f ? 255 : 50);
            int gb = hf > 0.7f ? 90 : (hf > 0.3f ? 0 : 0);
            if (fillH > 0) {
                glBegin(GL_QUADS); glColor3ub(gr, gg, gb);
                int fillY = by + boxH - 1 - fillH;
                glVertex2f((float)(barX + 1), (float)fillY); glVertex2f((float)(barX + 3), (float)fillY);
                glVertex2f((float)(barX + 3), (float)(by + boxH - 1)); glVertex2f((float)(barX + 1), (float)(by + boxH - 1));
                glEnd();
            }

            if (absFillH > 0) {
                int absStartY = by + boxH - 1 - fillH - absFillH;
                glBegin(GL_QUADS); glColor3ub(255, 255, 50);
                glVertex2f((float)(barX + 1), (float)absStartY); glVertex2f((float)(barX + 3), (float)absStartY);
                glVertex2f((float)(barX + 3), (float)(by + boxH - 1 - fillH)); glVertex2f((float)(barX + 1), (float)(by + boxH - 1 - fillH));
                glEnd();
            }
        }

        if (!e.name.empty()) {
            int baseFont = std::max(14, std::min(20, h / 55));
            int nameFontSize = std::max(baseFont, std::min(64, (int)(boxH / 7.0f)));

            char hpBuf[32];
            bool hasAbs = e.health > e.maxHealth;
            if (hasAbs) snprintf(hpBuf, sizeof(hpBuf), "  %.0f+%.0f", e.maxHealth, e.health - e.maxHealth);
            else snprintf(hpBuf, sizeof(hpBuf), "  %.0f", e.health);

            float nameW = (float)e.name.size() * nameFontSize * 0.56f;
            float hpW = (float)strlen(hpBuf) * nameFontSize * 0.56f;
            float totalW = nameW + hpW;
            int nx = centerX - (int)(totalW * 0.5f);
            int ny = by - nameFontSize - 6;

            float ty = (float)ny + (float)nameFontSize;
            DrawESPTextSized((float)nx, ty, e.name.c_str(), 255, 255, 255, nameFontSize);

            float hpFrac = e.maxHealth > 0 ? e.health / e.maxHealth : 0;
            int hR, hG, hB;
            if (hasAbs) { hR = 255; hG = 220; hB = 50; }
            else if (hpFrac > .7f) { hR = 85; hG = 255; hB = 100; }
            else if (hpFrac > .3f) { hR = 255; hG = 210; hB = 60; }
            else { hR = 255; hG = 70; hB = 70; }
            DrawESPTextSized((float)nx + nameW, ty, hpBuf, hR, hG, hB, nameFontSize);
        }
    }
}

static void hk_wglSwapBuffers_inner(HDC hDc) {
    InitGLFonts(hDc);
    if (g_settings.espShowHP && g_espCSReady && g_inGame) {
        glPushAttrib(GL_ALL_ATTRIB_BITS);
        glMatrixMode(GL_PROJECTION); glPushMatrix();
        glMatrixMode(GL_MODELVIEW); glPushMatrix();
        GLint viewport[4]; glGetIntegerv(GL_VIEWPORT, viewport);
        int w = viewport[2], h = viewport[3];
        glMatrixMode(GL_PROJECTION); glLoadIdentity(); glOrtho(0, w, h, 0, -1, 1);
        glMatrixMode(GL_MODELVIEW); glLoadIdentity();
        glDisable(GL_DEPTH_TEST); glDisable(GL_LIGHTING); glDisable(GL_TEXTURE_2D);
        glEnable(GL_BLEND); glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);
        DrawESPEntities(w, h);
        glMatrixMode(GL_PROJECTION); glPopMatrix();
        glMatrixMode(GL_MODELVIEW); glPopMatrix();
        glPopAttrib();
    }
}

BOOL WINAPI hk_wglSwapBuffers(HDC hDc) {
    __try { hk_wglSwapBuffers_inner(hDc); }
    __except (EXCEPTION_EXECUTE_HANDLER) {}
    return oWglSwapBuffers(hDc);
}

DWORD WINAPI SetupHookThread(LPVOID lpReserved) {
    Sleep(3000); HMODULE hMod = nullptr;
    for (int i = 0; i < 30; i++) { Sleep(1000); hMod = GetModuleHandleA("opengl32.dll"); if (hMod) break; }
    if (!hMod) return 1;
    void* pFunc = (void*)GetProcAddress(hMod, "wglSwapBuffers"); if (!pFunc) return 1;
    InstallHook(pFunc, &hk_wglSwapBuffers, (void**)&oWglSwapBuffers);
    Log("GL hook: %s", g_hookInstalled ? "OK" : "FAILED");
    return 0;
}

// ===================== JNI WORKER =====================
DWORD WINAPI JniWorkerThread(LPVOID param) {
    timeBeginPeriod(1);
    Sleep(18000);
    InitDataCS();
    InitMapCS();
    InitEspCS();

    bool init = false;
    for (int a = 0; a < 5; a++) {
        if (Java::Initialize()) { init = true; break; }
        Java::Cleanup();
        Sleep(5000);
    }

    if (!init) {
        snprintf(g_debugStatus, sizeof(g_debugStatus), "JNI INIT FAILED");
        g_jniRunning = false;
        timeEndPeriod(1);
        return 1;
    }

    snprintf(g_debugStatus, sizeof(g_debugStatus), "Ready - Features loaded");
    g_jniRunning = true;

    ULONGLONG lastIC = 0, lastPF = 0, lastMapFull = 0, lastMapPose = 0, lastEntities = 0;

    while (g_jniRunning) {
        ULONGLONG now = GetTickCount64();

        if (now - lastIC >= 200) {
            g_inGame = SafeIsInWorld();
            lastIC = now;
        }

        if (g_nickApplyPending && g_jniRunning && Java::env) {
            g_nickApplyPending = false;
            SafeApplyPendingNickname();
        }

        if (!g_inGame) {
            Sleep(80);
            continue;
        }

        // No jump / hit delay every ~16ms
        if ((g_settings.noJumpDelay || g_settings.noHitDelay) && (now - lastPF >= 16)) {
            if (!SafeApplyDelayPatches(g_settings.noJumpDelay, g_settings.noHitDelay)) {
                g_settings.noJumpDelay = false;
                g_settings.noHitDelay = false;
            }
            lastPF = now;
        }

        // === ESP Camera + Entities ===
        bool needEsp = g_settings.espShowHP;
        bool needMap = g_settings.mapEnabled;

        // Camera data for ESP (high frequency for smooth tracking)
        if (needEsp && now - lastMapPose >= 8) {
            __try { Java::UpdateCameraData(); }
            __except (EXCEPTION_EXECUTE_HANDLER) {}
            lastMapPose = now;
        }
        // Map pose (lower frequency)
        else if (needMap && !needEsp && now - lastMapPose >= 50) {
            float px, py, pz, yaw;
            if (Java::GetPlayerPose(px, py, pz, yaw)) {
                if (g_mapCSReady) {
                    EnterCriticalSection(&g_mapCS);
                    g_map.playerX = px; g_map.playerY = py; g_map.playerZ = pz; g_map.playerYaw = yaw;
                    LeaveCriticalSection(&g_mapCS);
                }
            }
            lastMapPose = now;
        }

        // Entity collection (shared between map + ESP)
        bool needEntities = needMap || needEsp;
        if (needEntities && now - lastEntities >= 100) {
            float px = g_map.playerX, pz = g_map.playerZ;
            std::vector<MapEntity> mapEnts;
            SafeEnumerateEntitiesRaw(&mapEnts, px, pz);

            if (g_mapCSReady) {
                EnterCriticalSection(&g_mapCS);
                g_map.entities = mapEnts;
                LeaveCriticalSection(&g_mapCS);
            }

            // ESP entities (separate collection for HP data)
            if (needEsp) {
                __try {
                    std::vector<EspEntityData> espEnts;
                    Java::CollectEspEntities(espEnts);
                    if (g_espCSReady) {
                        EnterCriticalSection(&g_espCS);
                        g_espEntities = std::move(espEnts);
                        LeaveCriticalSection(&g_espCS);
                    }
                }
                __except (EXCEPTION_EXECUTE_HANDLER) {}
            }
            lastEntities = now;
        }

        // Terrain sampling for minimap
        if (needMap && now - lastMapFull >= 80) {
            SafeUpdateMinimapData();
            lastMapFull = now;
        }

        Sleep(2);
    }

    Java::Cleanup();
    timeEndPeriod(1);
    return 0;
}

// ===================== MAIN THREAD =====================
void MainThread(HMODULE hModule) {
    LogInit();
    Log("=== Karvis Files v1 starting ===");

    Sleep(5000);

    g_mouseHookThreadHandle = CreateThread(nullptr, 0, MouseHookThread, hModule, 0, &g_mouseHookThreadId);
    if (!g_mouseHookThreadHandle) {
        FreeLibraryAndExitThread(hModule, 0);
        return;
    }

    for (int i = 0; i < 50 && !g_mouseHook; i++) Sleep(100);

    if (!CreateGuiWindow((HINSTANCE)hModule)) {
        if (g_mouseHookThreadId) PostThreadMessage(g_mouseHookThreadId, WM_QUIT, 0, 0);
        if (g_mouseHookThreadHandle) {
            WaitForSingleObject(g_mouseHookThreadHandle, 3000);
            CloseHandle(g_mouseHookThreadHandle);
        }
        FreeLibraryAndExitThread(hModule, 0);
        return;
    }

    // Map window thread (owns its own window/message loop)
    g_mapThreadHandle = CreateThread(nullptr, 0, MapWindowThread, hModule, 0, &g_mapThreadId);

    g_jniRunning = false;
    g_jniThread = CreateThread(nullptr, 0, JniWorkerThread, hModule, 0, nullptr);

    bool running = true, saw = false;

    while (running) {
        MsgWaitForMultipleObjects(0, nullptr, FALSE, 1, QS_ALLINPUT);
        MSG msg;
        while (PeekMessage(&msg, nullptr, 0, 0, PM_REMOVE)) {
            if (msg.message == WM_QUIT) { running = false; break; }
            TranslateMessage(&msg);
            DispatchMessage(&msg);
        }

        if (!running) break;

        // Toggle GUI visibility with SHIFT+ALT
        bool sd = (GetAsyncKeyState(VK_LSHIFT) & 0x8000) != 0;
        bool ad = (GetAsyncKeyState(VK_LMENU) & 0x8000) != 0;
        bool san = sd && ad;
        if (san && !saw) {
            if (!IsWindowVisible(g_hWnd)) ShowWindow(g_hWnd, SW_SHOWNOACTIVATE);
            else ShowWindow(g_hWnd, SW_HIDE);
        }
        saw = san;

        // Borderless fullscreen toggle
        if (g_f11Pressed) {
            g_f11Pressed = false;
            HWND game = FindGameWindow();
            if (game) ToggleBorderlessFullscreen(game);
        }

        // Mouse delay fix: only active while Minecraft is the foreground
        // window. Apply when MC gets focus with the toggle on, restore the
        // moment MC loses focus or the toggle is turned off. This keeps the
        // fix scoped to the game and avoids persisting system-wide pointer
        // changes to the desktop / other apps.
        {
            HWND mcWnd = FindGameWindow();
            bool mcForeground = IsMinecraftForegroundWindow(mcWnd);
            bool mouseInsideMc = IsCursorInsideWindow(mcWnd);
            bool shouldApply = g_settings.mouseDelayFix && g_inGame && mcForeground && mouseInsideMc;
            if (shouldApply && !g_mouseFixApplied) {
                ApplyMouseDelayFix();
            }
            else if (!shouldApply && g_mouseFixApplied) {
                RestoreMouseDelayFix();
            }
        }

        // DELETE key to unload
        if (GetAsyncKeyState(VK_DELETE) & 0x8000) {
            running = false;
        }
    }

    // Restore mouse settings before tearing anything else down.
    if (g_mouseFixApplied) RestoreMouseDelayFix();

    if (g_pOriginalWglSwapBuffers) RemoveHook(g_pOriginalWglSwapBuffers);

    // Shut down map thread
    g_mapRunning = false;
    if (g_mapThreadId) PostThreadMessage(g_mapThreadId, WM_QUIT, 0, 0);
    if (g_mapThreadHandle) {
        WaitForSingleObject(g_mapThreadHandle, 3000);
        CloseHandle(g_mapThreadHandle);
        g_mapThreadHandle = nullptr;
    }
    g_mapThreadId = 0;

    g_jniRunning = false;
    if (g_jniThread) {
        WaitForSingleObject(g_jniThread, 8000);
        CloseHandle(g_jniThread);
        g_jniThread = nullptr;
    }

    if (g_mouseHookThreadId) PostThreadMessage(g_mouseHookThreadId, WM_QUIT, 0, 0);
    if (g_mouseHookThreadHandle) {
        WaitForSingleObject(g_mouseHookThreadHandle, 3000);
        CloseHandle(g_mouseHookThreadHandle);
        g_mouseHookThreadHandle = nullptr;
    }
    g_mouseHookThreadId = 0;

    if (g_nickDialogWnd) { DestroyWindow(g_nickDialogWnd); g_nickDialogWnd = nullptr; }
    if (g_hWnd) DestroyWindow(g_hWnd);

    if (g_fontTitle) { DeleteObject(g_fontTitle); g_fontTitle = nullptr; }
    if (g_fontItem) { DeleteObject(g_fontItem); g_fontItem = nullptr; }
    if (g_fontSmall) { DeleteObject(g_fontSmall); g_fontSmall = nullptr; }
    if (g_fontTiny) { DeleteObject(g_fontTiny); g_fontTiny = nullptr; }

    if (g_dataCSReady) { DeleteCriticalSection(&g_dataCS); g_dataCSReady = false; }
    if (g_mapCSReady) { DeleteCriticalSection(&g_mapCS);  g_mapCSReady = false; }
    if (g_espCSReady) { DeleteCriticalSection(&g_espCS);  g_espCSReady = false; }

    Log("=== Karvis Files v1 unloading ===");
    FreeLibraryAndExitThread(hModule, 0);
}

// ===================== DLL ENTRY =====================
#pragma comment(linker, "/guard:no")
BOOL APIENTRY DllMain(HMODULE hModule, DWORD ul_reason_for_call, LPVOID lpReserved) {
    switch (ul_reason_for_call) {
    case DLL_PROCESS_ATTACH:
        DisableThreadLibraryCalls(hModule);
        CreateThread(nullptr, 0, SetupHookThread, hModule, 0, nullptr);
        CreateThread(nullptr, 0, (LPTHREAD_START_ROUTINE)MainThread, hModule, 0, nullptr);
        break;
    case DLL_PROCESS_DETACH:
        if (g_pOriginalWglSwapBuffers) RemoveHook(g_pOriginalWglSwapBuffers);
        break;
    }
    return TRUE;
}
