bool Java::InitCache() {
    if (cacheInitialized) return true;
    Log("=== InitCache ===");

    mcClass = (jclass)env->NewGlobalRef(FindClass("net/minecraft/client/Minecraft"));
    if (!mcClass) { Log("ERROR: MC class not found"); return false; }
    mcClassName = "net/minecraft/client/Minecraft";

    getMinecraftMethod = GetStaticMethodID(mcClass, "getMinecraft", "()Lnet/minecraft/client/Minecraft;");

    // EntityLivingBase for jump delay + HP / absorption
    jclass elTemp = FindClass("net/minecraft/entity/EntityLivingBase");
    if (elTemp) {
        entityLivingClass = (jclass)env->NewGlobalRef(elTemp);
        env->DeleteLocalRef(elTemp);
        field_jumpTicks = GetFieldID(entityLivingClass, "jumpTicks", "I");

        const char* ghN[] = { "getHealth", "func_110143_aJ", nullptr };
        method_getHealth = TryGetMethod(env, entityLivingClass, ghN, "()F");
        const char* gmhN[] = { "getMaxHealth", "func_110138_aP", nullptr };
        method_getMaxHealth = TryGetMethod(env, entityLivingClass, gmhN, "()F");
        const char* gaN[] = { "getAbsorptionAmount", "func_110139_bj", nullptr };
        method_getAbsorption = TryGetMethod(env, entityLivingClass, gaN, "()F");
    }

    // EntityPlayer + InventoryPlayer for helmet detection
    jclass epTemp = FindClass("net/minecraft/entity/player/EntityPlayer");
    if (epTemp) {
        playerClass = (jclass)env->NewGlobalRef(epTemp);
        env->DeleteLocalRef(epTemp);
        const char* invN[] = { "inventory", "field_71071_by", nullptr };
        field_playerInventory = TryGetField(env, playerClass, invN,
            "Lnet/minecraft/entity/player/InventoryPlayer;");
    }
    jclass ipTemp = FindClass("net/minecraft/entity/player/InventoryPlayer");
    if (ipTemp) {
        invPlayerClass = (jclass)env->NewGlobalRef(ipTemp);
        env->DeleteLocalRef(ipTemp);
        const char* armN[] = { "armorInventory", "field_70460_b", nullptr };
        field_armorInventory = TryGetField(env, invPlayerClass, armN,
            "[Lnet/minecraft/item/ItemStack;");
    }

    // Minecraft fields
    field_thePlayer = GetFieldID(mcClass, "thePlayer", "Lnet/minecraft/client/entity/EntityPlayerSP;");
    field_theWorld = GetFieldID(mcClass, "theWorld", "Lnet/minecraft/client/multiplayer/WorldClient;");
    field_currentScreen = GetFieldID(mcClass, "currentScreen", "Lnet/minecraft/client/gui/GuiScreen;");
    field_leftClickCounter = GetFieldID(mcClass, "leftClickCounter", "I");

    // Session for nickname
    const char* sessN[] = { "session", "field_71449_j", nullptr };
    field_session = TryGetField(env, mcClass, sessN, "Lnet/minecraft/util/Session;");

    if (field_session) {
        jobject mc2 = GetMinecraft();
        if (mc2) {
            jobject sess = env->GetObjectField(mc2, field_session);
            if (sess) {
                jclass sc = env->GetObjectClass(sess);
                if (sc) {
                    sessionClass = (jclass)env->NewGlobalRef(sc);
                    const char* unN[] = { "username", "field_74286_b", nullptr };
                    field_sessionUsername = TryGetField(env, sc, unN, "Ljava/lang/String;");
                    env->DeleteLocalRef(sc);
                }
                env->DeleteLocalRef(sess);
            }
            env->DeleteLocalRef(mc2);
        }
    }

    // Entity class
    jclass eT = FindClass("net/minecraft/entity/Entity");
    if (eT) {
        entityClass = (jclass)env->NewGlobalRef(eT);
        env->DeleteLocalRef(eT);
        field_posX = GetFieldID(entityClass, "posX", "D");
        field_posY = GetFieldID(entityClass, "posY", "D");
        field_posZ = GetFieldID(entityClass, "posZ", "D");
        field_rotationYaw = GetFieldID(entityClass, "rotationYaw", "F");
        field_rotationPitch = GetFieldID(entityClass, "rotationPitch", "F");
        const char* gnN[] = { "getName", "func_70005_c_", nullptr };
        method_getName = TryGetMethod(env, entityClass, gnN, "()Ljava/lang/String;");
        const char* cnN[] = { "getCommandSenderName", "func_70005_c_", nullptr };
        method_getCommandSenderName = TryGetMethod(env, entityClass, cnN, "()Ljava/lang/String;");
    }

    // World / BlockPos / BlockState / Block / MapColor
    jclass wT = FindClass("net/minecraft/world/World");
    if (wT) {
        worldClass = (jclass)env->NewGlobalRef(wT);
        env->DeleteLocalRef(wT);
        const char* gbsN[] = { "getBlockState", "func_180495_p", nullptr };
        method_getBlockState = TryGetMethod(env, worldClass, gbsN,
            "(Lnet/minecraft/util/BlockPos;)Lnet/minecraft/block/state/IBlockState;");
        const char* leN[] = { "loadedEntityList", "field_72996_f", nullptr };
        field_loadedEntityList = TryGetField(env, worldClass, leN, "Ljava/util/List;");
        const char* peN[] = { "playerEntities", "field_73010_i", nullptr };
        field_playerEntities = TryGetField(env, worldClass, peN, "Ljava/util/List;");
    }

    jclass bpT = FindClass("net/minecraft/util/BlockPos");
    if (bpT) {
        blockPosClass = (jclass)env->NewGlobalRef(bpT);
        env->DeleteLocalRef(bpT);
        blockPosCtor = GetMethodID(blockPosClass, "<init>", "(III)V");
    }

    jclass ibsT = FindClass("net/minecraft/block/state/IBlockState");
    if (ibsT) {
        iBlockStateClass = (jclass)env->NewGlobalRef(ibsT);
        env->DeleteLocalRef(ibsT);
        const char* gbN[] = { "getBlock", "func_177230_c", nullptr };
        method_ibs_getBlock = TryGetMethod(env, iBlockStateClass, gbN,
            "()Lnet/minecraft/block/Block;");
    }

    jclass bT = FindClass("net/minecraft/block/Block");
    if (bT) {
        blockClass = (jclass)env->NewGlobalRef(bT);
        env->DeleteLocalRef(bT);
        const char* mcnN[] = { "getMapColor", "func_180659_g", nullptr };
        method_block_getMapColor = TryGetMethod(env, blockClass, mcnN,
            "(Lnet/minecraft/block/state/IBlockState;)Lnet/minecraft/block/material/MapColor;");
        const char* uN[] = { "getUnlocalizedName", "func_149739_a", nullptr };
        method_block_getUnlocalizedName = TryGetMethod(env, blockClass, uN, "()Ljava/lang/String;");
    }

    jclass mcT = FindClass("net/minecraft/block/material/MapColor");
    if (mcT) {
        mapColorClass = (jclass)env->NewGlobalRef(mcT);
        env->DeleteLocalRef(mcT);
        const char* cvN[] = { "colorValue", "field_76291_p", nullptr };
        field_mapColor_value = TryGetField(env, mapColorClass, cvN, "I");
    }

    // List
    jclass lT = env->FindClass("java/util/List");
    if (env->ExceptionCheck()) env->ExceptionClear();
    if (lT) {
        listClass = (jclass)env->NewGlobalRef(lT);
        env->DeleteLocalRef(lT);
        method_list_size = GetMethodID(listClass, "size", "()I");
        method_list_get = GetMethodID(listClass, "get", "(I)Ljava/lang/Object;");
    }

    jclass sT = env->FindClass("java/lang/String");
    if (env->ExceptionCheck()) env->ExceptionClear();
    if (sT) { stringClass = (jclass)env->NewGlobalRef(sT); env->DeleteLocalRef(sT); }


    // === Camera / Matrix fields for ESP ===
    if (mcClass) {
        field_gameSettings = GetFieldID(mcClass, "gameSettings", "Lnet/minecraft/client/settings/GameSettings;");
        if (field_gameSettings) {
            jobject mc3 = GetMinecraft();
            if (mc3) {
                jobject gs = env->GetObjectField(mc3, field_gameSettings);
                if (gs) {
                    jclass gsC = env->GetObjectClass(gs);
                    if (gsC) {
                        field_fovSetting = GetFieldID(gsC, "fovSetting", "F");
                        env->DeleteLocalRef(gsC);
                    }
                    env->DeleteLocalRef(gs);
                }
                env->DeleteLocalRef(mc3);
            }
        }

        // Timer / renderPartialTicks
        field_timer = GetFieldID(mcClass, "timer", "Lnet/minecraft/util/Timer;");
        if (!field_timer && jvmti) {
            jint fc = 0; jfieldID* fl = nullptr;
            if (jvmti->GetClassFields(mcClass, &fc, &fl) == JVMTI_ERROR_NONE) {
                for (int i = 0; i < fc && !field_timer; i++) {
                    char* fn = nullptr; char* fs = nullptr;
                    jvmti->GetFieldName(mcClass, fl[i], &fn, &fs, nullptr);
                    if (fs && fs[0] == 'L') {
                        jint mods = 0; jvmti->GetFieldModifiers(mcClass, fl[i], &mods);
                        if (!(mods & 0x0008)) {
                            std::string cn(fs + 1, strlen(fs) - 2);
                            jclass tc = FindClass(cn.c_str());
                            if (tc) {
                                jfieldID rpt = env->GetFieldID(tc, "renderPartialTicks", "F");
                                if (!rpt || env->ExceptionCheck()) {
                                    env->ExceptionClear();
                                    rpt = env->GetFieldID(tc, "field_74281_c", "F");
                                    if (env->ExceptionCheck()) { env->ExceptionClear(); rpt = nullptr; }
                                }
                                if (rpt) { field_timer = fl[i]; field_renderPartialTicks = rpt; }
                                env->DeleteLocalRef(tc);
                            }
                        }
                    }
                    if (fn) jvmti->Deallocate((unsigned char*)fn);
                    if (fs) jvmti->Deallocate((unsigned char*)fs);
                }
                jvmti->Deallocate((unsigned char*)fl);
            }
        }
    }

    // ActiveRenderInfo (MODELVIEW, PROJECTION buffers)
    {
        const char* ariN[] = { "net/minecraft/client/renderer/ActiveRenderInfo", nullptr };
        jclass ariT = FindClass(ariN[0]);
        if (ariT) {
            activeRenderInfoClass = (jclass)env->NewGlobalRef(ariT);
            env->DeleteLocalRef(ariT);

            const char* mvN[] = { "MODELVIEW", "field_178812_b", nullptr };
            for (int i = 0; mvN[i]; i++) {
                jfieldID f = env->GetStaticFieldID(activeRenderInfoClass, mvN[i], "Ljava/nio/FloatBuffer;");
                if (f && !env->ExceptionCheck()) { field_ariModelview = f; break; }
                env->ExceptionClear();
            }
            const char* prN[] = { "PROJECTION", "field_178813_c", nullptr };
            for (int i = 0; prN[i]; i++) {
                jfieldID f = env->GetStaticFieldID(activeRenderInfoClass, prN[i], "Ljava/nio/FloatBuffer;");
                if (f && !env->ExceptionCheck()) { field_ariProjection = f; break; }
                env->ExceptionClear();
            }

            if ((!field_ariModelview || !field_ariProjection) && jvmti) {
                jint ac = 0; jfieldID* af = nullptr;
                if (jvmti->GetClassFields(activeRenderInfoClass, &ac, &af) == JVMTI_ERROR_NONE) {
                    jfieldID fb[4]; int fbc = 0;
                    for (int i = 0; i < ac && fbc < 4; i++) {
                        char* n = nullptr; char* s2 = nullptr;
                        jvmti->GetFieldName(activeRenderInfoClass, af[i], &n, &s2, nullptr);
                        if (s2 && strcmp(s2, "Ljava/nio/FloatBuffer;") == 0) {
                            jint m = 0; jvmti->GetFieldModifiers(activeRenderInfoClass, af[i], &m);
                            if (m & 0x0008) fb[fbc++] = af[i];
                        }
                        if (n) jvmti->Deallocate((unsigned char*)n);
                        if (s2) jvmti->Deallocate((unsigned char*)s2);
                    }
                    if (fbc >= 2) {
                        if (!field_ariModelview) field_ariModelview = fb[0];
                        if (!field_ariProjection) field_ariProjection = fb[1];
                    }
                    jvmti->Deallocate((unsigned char*)af);
                }
            }
        }
    }

    // RenderManager (renderPosX/Y/Z)
    {
        const char* grmN[] = { "getRenderManager", "func_175598_ae", nullptr };
        method_getRenderManager = TryGetMethod(env, mcClass, grmN, "()Lnet/minecraft/client/renderer/entity/RenderManager;");
        jclass rmT = FindClass("net/minecraft/client/renderer/entity/RenderManager");
        if (rmT) {
            renderManagerClass = (jclass)env->NewGlobalRef(rmT);
            env->DeleteLocalRef(rmT);
            const char* rpxN[] = { "renderPosX", "field_78725_b", nullptr };
            field_renderPosX = TryGetField(env, renderManagerClass, rpxN, "D");
            const char* rpyN[] = { "renderPosY", "field_78726_c", nullptr };
            field_renderPosY = TryGetField(env, renderManagerClass, rpyN, "D");
            const char* rpzN[] = { "renderPosZ", "field_78723_d", nullptr };
            field_renderPosZ = TryGetField(env, renderManagerClass, rpzN, "D");
        }
    }

    if (entityClass) {
        field_prevPosX = GetFieldID(entityClass, "prevPosX", "D");
        field_prevPosY = GetFieldID(entityClass, "prevPosY", "D");
        field_prevPosZ = GetFieldID(entityClass, "prevPosZ", "D");
        field_isDead = GetFieldID(entityClass, "isDead", "Z");
        field_height = GetFieldID(entityClass, "height", "F");
        const char* eidN[] = { "entityId", "field_145783_c", nullptr };
        field_entityId = TryGetField(env, entityClass, eidN, "I");
    }

    {
        jclass epT = FindClass("net/minecraft/entity/player/EntityPlayer");
        if (epT) {
            entityPlayerClass = (jclass)env->NewGlobalRef(epT);
            env->DeleteLocalRef(epT);
        }
    }

    {
        const char* asN[] = { "net/minecraft/entity/item/EntityArmorStand", nullptr };
        jclass asT = FindClass(asN[0]);
        if (asT) { armorStandClass = (jclass)env->NewGlobalRef(asT); env->DeleteLocalRef(asT); }
    }

    Log("ESP camera: ariMV=%s ariProj=%s rmPos=%s timer=%s fov=%s entityId=%s isDead=%s height=%s",
        field_ariModelview ? "OK" : "NULL", field_ariProjection ? "OK" : "NULL",
        (field_renderPosX && field_renderPosY && field_renderPosZ) ? "OK" : "NULL",
        field_timer ? "OK" : "NULL", field_fovSetting ? "OK" : "NULL",
        field_entityId ? "OK" : "NULL", field_isDead ? "OK" : "NULL", field_height ? "OK" : "NULL");

    cacheInitialized = true;
    Log("InitCache complete (mapSupport=%s, entitySupport=%s)",
        (method_getBlockState && blockPosCtor ? "YES" : "NO"),
        (field_loadedEntityList && field_posX ? "YES" : "NO"));
    return true;
}

void Java::Cleanup() {
    if (env) {
        if (mcClass) { env->DeleteGlobalRef(mcClass); mcClass = nullptr; }
        if (entityLivingClass) { env->DeleteGlobalRef(entityLivingClass); entityLivingClass = nullptr; }
        if (sessionClass) { env->DeleteGlobalRef(sessionClass); sessionClass = nullptr; }
        if (entityClass) { env->DeleteGlobalRef(entityClass); entityClass = nullptr; }
        if (worldClass) { env->DeleteGlobalRef(worldClass); worldClass = nullptr; }
        if (blockPosClass) { env->DeleteGlobalRef(blockPosClass); blockPosClass = nullptr; }
        if (iBlockStateClass) { env->DeleteGlobalRef(iBlockStateClass); iBlockStateClass = nullptr; }
        if (blockClass) { env->DeleteGlobalRef(blockClass); blockClass = nullptr; }
        if (mapColorClass) { env->DeleteGlobalRef(mapColorClass); mapColorClass = nullptr; }
        if (listClass) { env->DeleteGlobalRef(listClass); listClass = nullptr; }
        if (stringClass) { env->DeleteGlobalRef(stringClass); stringClass = nullptr; }
        if (activeRenderInfoClass) { env->DeleteGlobalRef(activeRenderInfoClass); activeRenderInfoClass = nullptr; }
        if (renderManagerClass) { env->DeleteGlobalRef(renderManagerClass); renderManagerClass = nullptr; }
        if (armorStandClass) { env->DeleteGlobalRef(armorStandClass); armorStandClass = nullptr; }
        if (entityPlayerClass) { env->DeleteGlobalRef(entityPlayerClass); entityPlayerClass = nullptr; }
        if (cachedClassLoader) { env->DeleteGlobalRef(cachedClassLoader); cachedClassLoader = nullptr; }
    }
    if (jvm && attached) {
        jvm->DetachCurrentThread();
        attached = false;
    }
    env = nullptr;
    jvmti = nullptr;
    field_ariModelview = field_ariProjection = nullptr;
    method_getRenderManager = nullptr;
    field_renderPosX = field_renderPosY = field_renderPosZ = nullptr;
    field_timer = field_renderPartialTicks = nullptr;
    field_gameSettings = field_fovSetting = nullptr;
    field_prevPosX = field_prevPosY = field_prevPosZ = nullptr;
    field_isDead = field_height = nullptr;
    field_entityId = nullptr;
    cacheInitialized = false;
}

jobject Java::GetMinecraft() {
    if (!env || !mcClass || !getMinecraftMethod) return nullptr;
    jobject mc = env->CallStaticObjectMethod(mcClass, getMinecraftMethod);
    if (env->ExceptionCheck()) { env->ExceptionClear(); return nullptr; }
    return mc;
}

jobject Java::GetPlayer() {
    jobject mc = GetMinecraft();
    if (!mc || !field_thePlayer) { if (mc) env->DeleteLocalRef(mc); return nullptr; }
    jobject p = env->GetObjectField(mc, field_thePlayer);
    env->DeleteLocalRef(mc);
    return p;
}

jobject Java::GetWorld() {
    jobject mc = GetMinecraft();
    if (!mc || !field_theWorld) { if (mc) env->DeleteLocalRef(mc); return nullptr; }
    jobject w = env->GetObjectField(mc, field_theWorld);
    env->DeleteLocalRef(mc);
    return w;
}

bool Java::IsInWorld() {
    jobject mc = GetMinecraft();
    if (!mc) return false;
    jobject pl = field_thePlayer ? env->GetObjectField(mc, field_thePlayer) : nullptr;
    jobject wl = field_theWorld ? env->GetObjectField(mc, field_theWorld) : nullptr;
    bool ig = (pl && wl);
    if (pl) env->DeleteLocalRef(pl);
    if (wl) env->DeleteLocalRef(wl);
    env->DeleteLocalRef(mc);
    return ig;
}

