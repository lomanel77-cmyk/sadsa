// Fallback color from unlocalized name substring
static COLORREF FallbackColorFromName(const char* n, uint8_t& flags) {
    flags = 0;
    if (!n) return RGB(120, 120, 120);
    std::string s(n);
    for (auto& c : s) c = (char)tolower((unsigned char)c);

    if (s.find("diamond") != std::string::npos) { flags |= 1; return RGB(90, 230, 220); }
    if (s.find("emerald") != std::string::npos) { flags |= 1; return RGB(60, 220, 80); }
    if (s.find("gold") != std::string::npos) { flags |= 1; return RGB(255, 215, 80); }
    if (s.find("iron") != std::string::npos) { flags |= 1; return RGB(200, 180, 160); }
    if (s.find("lapis") != std::string::npos) { flags |= 1; return RGB(60, 90, 200); }
    if (s.find("redstone") != std::string::npos) { flags |= 1; return RGB(220, 40, 40); }
    if (s.find("coal") != std::string::npos) { flags |= 1; return RGB(40, 40, 48); }
    if (s.find("quartz") != std::string::npos) { flags |= 1; return RGB(235, 230, 220); }

    if (s.find("water") != std::string::npos) { flags |= 4; return RGB(50, 80, 200); }
    if (s.find("lava") != std::string::npos) { return RGB(240, 120, 30); }
    if (s.find("grass") != std::string::npos) return RGB(90, 170, 60);
    if (s.find("leaves") != std::string::npos) return RGB(50, 130, 50);
    if (s.find("log") != std::string::npos || s.find("wood") != std::string::npos) return RGB(110, 80, 45);
    if (s.find("sand") != std::string::npos) return RGB(220, 210, 150);
    if (s.find("gravel") != std::string::npos) return RGB(140, 130, 120);
    if (s.find("dirt") != std::string::npos) return RGB(120, 85, 55);
    if (s.find("stone") != std::string::npos) return RGB(110, 110, 115);
    if (s.find("snow") != std::string::npos || s.find("ice") != std::string::npos) return RGB(235, 240, 250);
    if (s.find("air") != std::string::npos) return RGB(0, 0, 0);
    return RGB(130, 130, 140);
}

int Java::GetBlockColorAt(int bx, int by, int bz, uint8_t& flagsOut) {
    flagsOut = 0;
    if (!env || !worldClass || !blockPosClass || !method_getBlockState ||
        !method_ibs_getBlock || !blockPosCtor) return -1;

    jobject mc = GetMinecraft();
    if (!mc) return -1;
    jobject world = env->GetObjectField(mc, field_theWorld);
    env->DeleteLocalRef(mc);
    if (!world) return -1;

    jobject bp = env->NewObject(blockPosClass, blockPosCtor, bx, by, bz);
    if (env->ExceptionCheck()) { env->ExceptionClear(); env->DeleteLocalRef(world); return -1; }
    if (!bp) { env->DeleteLocalRef(world); return -1; }

    jobject state = env->CallObjectMethod(world, method_getBlockState, bp);
    if (env->ExceptionCheck()) { env->ExceptionClear(); env->DeleteLocalRef(bp); env->DeleteLocalRef(world); return -1; }
    env->DeleteLocalRef(bp);
    env->DeleteLocalRef(world);
    if (!state) return -1;

    jobject block = env->CallObjectMethod(state, method_ibs_getBlock);
    if (env->ExceptionCheck()) { env->ExceptionClear(); env->DeleteLocalRef(state); return -1; }
    if (!block) { env->DeleteLocalRef(state); return -1; }

    int color = -1;
    bool haveColor = false;

    // Try MapColor first
    if (method_block_getMapColor && field_mapColor_value) {
        jobject mc2 = env->CallObjectMethod(block, method_block_getMapColor, state);
        if (env->ExceptionCheck()) { env->ExceptionClear(); }
        else if (mc2) {
            jint cv = env->GetIntField(mc2, field_mapColor_value);
            color = (int)cv & 0xFFFFFF;
            haveColor = true;
            env->DeleteLocalRef(mc2);
        }
    }

    // Always get name for ore detection / fallback
    if (method_block_getUnlocalizedName) {
        jstring jn = (jstring)env->CallObjectMethod(block, method_block_getUnlocalizedName);
        if (env->ExceptionCheck()) env->ExceptionClear();
        if (jn) {
            const char* utf = env->GetStringUTFChars(jn, nullptr);
            if (utf) {
                uint8_t nf = 0;
                COLORREF cf = FallbackColorFromName(utf, nf);
                flagsOut |= nf;
                if (!haveColor) {
                    color = (int)cf & 0xFFFFFF;
                    haveColor = true;
                }
                env->ReleaseStringUTFChars(jn, utf);
            }
            env->DeleteLocalRef(jn);
        }
    }

    env->DeleteLocalRef(block);
    env->DeleteLocalRef(state);

    if (!haveColor) return -1;
    // MapColor int is stored as RGB packed. Convert MC (R<<16|G<<8|B) -> COLORREF (B<<16|G<<8|R)
    int r = (color >> 16) & 0xFF;
    int g = (color >> 8) & 0xFF;
    int b = color & 0xFF;
    return (int)RGB(r, g, b);
}

void Java::EnumerateEntities(std::vector<MapEntity>& out, float selfX, float selfZ) {
    out.clear();
    if (!env || !listClass || !field_loadedEntityList || !entityClass ||
        !field_posX || !field_posY || !field_posZ) return;

    jobject mc = GetMinecraft();
    if (!mc) return;
    jobject world = env->GetObjectField(mc, field_theWorld);
    jobject thePlayer = field_thePlayer ? env->GetObjectField(mc, field_thePlayer) : nullptr;
    env->DeleteLocalRef(mc);
    if (!world) { if (thePlayer) env->DeleteLocalRef(thePlayer); return; }

    jobject list = env->GetObjectField(world, field_loadedEntityList);
    // Build a set of "real" player refs from World.playerEntities so we can
    // distinguish actual connected players from NPCs that happen to extend
    // an EntityPlayer subclass (e.g. Citizens-style bots).
    std::vector<jobject> realPlayers;
    if (field_playerEntities) {
        jobject pList = env->GetObjectField(world, field_playerEntities);
        if (pList) {
            jint pn = env->CallIntMethod(pList, method_list_size);
            if (env->ExceptionCheck()) { env->ExceptionClear(); pn = 0; }
            if (pn > 64) pn = 64;
            realPlayers.reserve((size_t)pn);
            for (jint j = 0; j < pn; j++) {
                jobject pe = env->CallObjectMethod(pList, method_list_get, j);
                if (env->ExceptionCheck()) { env->ExceptionClear(); continue; }
                if (pe) realPlayers.push_back(pe); // local refs; released at end
            }
            env->DeleteLocalRef(pList);
        }
    }
    env->DeleteLocalRef(world);
    if (!list) {
        for (auto r : realPlayers) env->DeleteLocalRef(r);
        if (thePlayer) env->DeleteLocalRef(thePlayer);
        return;
    }

    jint size = env->CallIntMethod(list, method_list_size);
    if (env->ExceptionCheck()) {
        env->ExceptionClear();
        env->DeleteLocalRef(list);
        for (auto r : realPlayers) env->DeleteLocalRef(r);
        if (thePlayer) env->DeleteLocalRef(thePlayer);
        return;
    }
    if (size < 0) size = 0;
    if (size > 512) size = 512; // safety cap

    out.reserve((size_t)size);

    for (jint i = 0; i < size; i++) {
        jobject e = env->CallObjectMethod(list, method_list_get, i);
        if (env->ExceptionCheck()) { env->ExceptionClear(); continue; }
        if (!e) continue;

        double ex = env->GetDoubleField(e, field_posX);
        double ey = env->GetDoubleField(e, field_posY);
        double ez = env->GetDoubleField(e, field_posZ);
        float eyaw = env->GetFloatField(e, field_rotationYaw);

        float dx = (float)ex - selfX;
        float dz = (float)ez - selfZ;
        float dist2 = dx * dx + dz * dz;
        if (dist2 > 200.f * 200.f) { env->DeleteLocalRef(e); continue; }

        // Determine type from class name
        jclass ec = env->GetObjectClass(e);
        char classSig[256] = {};
        if (jvmti && ec) {
            char* sig = nullptr;
            jvmti->GetClassSignature(ec, &sig, nullptr);
            if (sig) { strncpy_s(classSig, sig, sizeof(classSig) - 1); jvmti->Deallocate((unsigned char*)sig); }
        }
        if (ec) env->DeleteLocalRef(ec);

        MapEntity me = {};
        me.x = (float)ex; me.y = (float)ey; me.z = (float)ez; me.yaw = eyaw;
        me.kind = 4; // default: item/other

        // Self-filter: the local player is in loadedEntityList too.
        if (thePlayer && env->IsSameObject(e, thePlayer)) me.isSelf = true;

        std::string cs(classSig);
        for (auto& c : cs) c = (char)tolower((unsigned char)c);

        bool classNpcHint = cs.find("npc") != std::string::npos || cs.find("citizens") != std::string::npos ||
            cs.find("human") != std::string::npos;

        bool isPlayer = cs.find("player") != std::string::npos;
        // Real player = present in World.playerEntities. NPC bots that extend
        // EntityPlayer* but aren't in that list are filtered out.
        if (isPlayer) {
            for (auto rp : realPlayers) {
                if (env->IsSameObject(e, rp)) { me.isRealPlayer = true; break; }
            }
        }
        bool isHostile = cs.find("zombie") != std::string::npos || cs.find("skeleton") != std::string::npos
            || cs.find("creeper") != std::string::npos || cs.find("spider") != std::string::npos
            || cs.find("enderman") != std::string::npos || cs.find("witch") != std::string::npos
            || cs.find("slime") != std::string::npos || cs.find("blaze") != std::string::npos
            || cs.find("ghast") != std::string::npos || cs.find("pigzombie") != std::string::npos
            || cs.find("wither") != std::string::npos || cs.find("silverfish") != std::string::npos
            || cs.find("guardian") != std::string::npos || cs.find("shulker") != std::string::npos;
        bool isPassive = cs.find("cow") != std::string::npos || cs.find("pig") != std::string::npos
            || cs.find("sheep") != std::string::npos || cs.find("chicken") != std::string::npos
            || cs.find("horse") != std::string::npos || cs.find("rabbit") != std::string::npos
            || cs.find("villager") != std::string::npos || cs.find("wolf") != std::string::npos
            || cs.find("ocelot") != std::string::npos || cs.find("bat") != std::string::npos
            || cs.find("squid") != std::string::npos || cs.find("snowman") != std::string::npos
            || cs.find("irongolem") != std::string::npos;

        if (isPlayer) me.kind = 1;
        else if (isHostile) me.kind = 2;
        else if (isPassive) me.kind = 3;
        else me.kind = 4;

        // Get name
        me.name[0] = 0;
        if (method_getName || method_getCommandSenderName) {
            jstring jn = nullptr;
            if (method_getName) {
                jn = (jstring)env->CallObjectMethod(e, method_getName);
                if (env->ExceptionCheck()) { env->ExceptionClear(); jn = nullptr; }
            }
            if (!jn && method_getCommandSenderName) {
                jn = (jstring)env->CallObjectMethod(e, method_getCommandSenderName);
                if (env->ExceptionCheck()) { env->ExceptionClear(); jn = nullptr; }
            }
            if (jn) {
                const char* u = env->GetStringUTFChars(jn, nullptr);
                if (u) {
                    strncpy_s(me.name, u, sizeof(me.name) - 1);
                    env->ReleaseStringUTFChars(jn, u);
                }
                env->DeleteLocalRef(jn);
            }
        }

        std::string nm(me.name);
        for (auto& c : nm) c = (char)tolower((unsigned char)c);
        bool nameNpcHint = nm.find("npc") != std::string::npos || nm.find("shop") != std::string::npos ||
            nm.find("seller") != std::string::npos || nm.find("quest") != std::string::npos;
        me.isNpc = classNpcHint || (nameNpcHint && !me.isRealPlayer);

        // Head color from name hash (deterministic per nickname)
        if (me.kind == 1 && me.name[0]) {
            unsigned h = 2166136261u;
            for (const char* p = me.name; *p; p++) { h ^= (unsigned char)*p; h *= 16777619u; }
            int hue = (int)(h % 360);
            float s = 0.55f, v = 0.95f;
            float c = v * s, x2 = c * (1 - fabsf(fmodf(hue / 60.0f, 2) - 1)), m = v - c;
            float r = 0, g = 0, b = 0;
            if (hue < 60) { r = c; g = x2; }
            else if (hue < 120) { r = x2; g = c; }
            else if (hue < 180) { g = c; b = x2; }
            else if (hue < 240) { g = x2; b = c; }
            else if (hue < 300) { r = x2; b = c; }
            else { r = c; b = x2; }
            me.headColor = RGB((int)((r + m) * 255), (int)((g + m) * 255), (int)((b + m) * 255));
        }
        else if (me.kind == 2) me.headColor = RGB(220, 60, 60);
        else if (me.kind == 3) me.headColor = RGB(90, 190, 90);
        else me.headColor = RGB(180, 180, 180);

        // Health + absorption ONLY for actual EntityLivingBase instances.
        // Calling getHealth() on a plain Entity (e.g. dropped item, arrow,
        // xp orb) dispatches through a vtable that doesn't own the method
        // and JVM-crashes the client. IsInstanceOf gates the call safely.
        bool isLiving = (entityLivingClass && env->IsInstanceOf(e, entityLivingClass));
        if (env->ExceptionCheck()) { env->ExceptionClear(); isLiving = false; }
        if (isLiving) {
            if (method_getHealth) {
                me.health = env->CallFloatMethod(e, method_getHealth);
                if (env->ExceptionCheck()) { env->ExceptionClear(); me.health = 0.f; }
            }
            if (method_getMaxHealth) {
                me.maxHealth = env->CallFloatMethod(e, method_getMaxHealth);
                if (env->ExceptionCheck()) { env->ExceptionClear(); me.maxHealth = 0.f; }
            }
            if (method_getAbsorption) {
                me.absorption = env->CallFloatMethod(e, method_getAbsorption);
                if (env->ExceptionCheck()) { env->ExceptionClear(); me.absorption = 0.f; }
            }
        }

        // Helmet detection: armorInventory[3] non-null = head slot occupied.
        if (me.isRealPlayer && field_playerInventory && field_armorInventory) {
            jobject inv = env->GetObjectField(e, field_playerInventory);
            if (env->ExceptionCheck()) { env->ExceptionClear(); inv = nullptr; }
            if (inv) {
                jobject arr = env->GetObjectField(inv, field_armorInventory);
                if (env->ExceptionCheck()) { env->ExceptionClear(); arr = nullptr; }
                if (arr) {
                    jobjectArray a = (jobjectArray)arr;
                    jsize len = env->GetArrayLength(a);
                    if (len >= 4) {
                        jobject helm = env->GetObjectArrayElement(a, 3);
                        if (env->ExceptionCheck()) { env->ExceptionClear(); helm = nullptr; }
                        if (helm) { me.hasHelmet = true; env->DeleteLocalRef(helm); }
                    }
                    env->DeleteLocalRef(arr);
                }
                env->DeleteLocalRef(inv);
            }
        }

        out.push_back(me);
        env->DeleteLocalRef(e);
    }

    for (auto r : realPlayers) env->DeleteLocalRef(r);
    if (thePlayer) env->DeleteLocalRef(thePlayer);
    env->DeleteLocalRef(list);
}


float Java::ReadPartialTicks() {
    if (!env || !field_timer || !field_renderPartialTicks) return 0.5f;
    jobject mc = GetMinecraft(); if (!mc) return 0.5f;
    jobject tObj = env->GetObjectField(mc, field_timer); env->DeleteLocalRef(mc);
    if (!tObj) return 0.5f;
    float pt = env->GetFloatField(tObj, field_renderPartialTicks); env->DeleteLocalRef(tObj);
    if (pt < 0.0f || pt > 1.0f) pt = 0.5f;
    return pt;
}

float Java::GetFOV() {
    if (!env || !field_gameSettings || !field_fovSetting) return 70.0f;
    jobject mc = GetMinecraft(); if (!mc) return 70.0f;
    jobject gs = env->GetObjectField(mc, field_gameSettings); env->DeleteLocalRef(mc);
    if (!gs) return 70.0f;
    float fov = env->GetFloatField(gs, field_fovSetting); env->DeleteLocalRef(gs);
    return (fov < 1 || fov > 179) ? 70.0f : fov;
}

void Java::UpdateCameraData() {
    if (!env) return;
    jobject player = GetPlayer(); if (!player) return;
    float pt = ReadPartialTicks();

    float localMV[16] = {}; float localProj[16] = {}; bool matricesOK = false;

    Vec3 cur = { env->GetDoubleField(player, field_posX), env->GetDoubleField(player, field_posY), env->GetDoubleField(player, field_posZ) };
    Vec3 prev = {};
    if (field_prevPosX) prev.x = env->GetDoubleField(player, field_prevPosX);
    if (field_prevPosY) prev.y = env->GetDoubleField(player, field_prevPosY);
    if (field_prevPosZ) prev.z = env->GetDoubleField(player, field_prevPosZ);

    Vec3 renderPos = { 0,0,0 }; bool gotRM = false;
    if (method_getRenderManager && field_renderPosX) {
        jobject mc = GetMinecraft();
        if (mc) {
            jobject rm = env->CallObjectMethod(mc, method_getRenderManager);
            if (rm && !env->ExceptionCheck()) {
                renderPos.x = env->GetDoubleField(rm, field_renderPosX);
                renderPos.y = env->GetDoubleField(rm, field_renderPosY);
                renderPos.z = env->GetDoubleField(rm, field_renderPosZ);
                env->DeleteLocalRef(rm); gotRM = true;
            }
            else { env->ExceptionClear(); }
            env->DeleteLocalRef(mc);
        }
    }
    if (!gotRM) {
        renderPos.x = prev.x + (cur.x - prev.x) * pt;
        renderPos.y = prev.y + (cur.y - prev.y) * pt;
        renderPos.z = prev.z + (cur.z - prev.z) * pt;
    }

    Vec3 camPos = { renderPos.x, renderPos.y + 1.62, renderPos.z };
    Rotation camRot = { 0, 0 }; float camFov = 70.0f;
    bool gotRot = false, gotFov = false;

    if (activeRenderInfoClass && field_ariModelview) {
        jobject mvBuf = env->GetStaticObjectField(activeRenderInfoClass, field_ariModelview);
        if (mvBuf) {
            float* mv = (float*)env->GetDirectBufferAddress(mvBuf);
            if (mv && (fabsf(mv[0]) > 0.0001f || fabsf(mv[5]) > 0.0001f)) {
                memcpy(localMV, mv, 16 * sizeof(float));
                float sinP = mv[6];
                if (sinP >= -1.0f && sinP <= 1.0f) {
                    camRot.pitch = (float)(asin((double)sinP) * 180.0 / KARVIS_PI);
                    float rawYaw = (float)(atan2((double)mv[8], (double)mv[0]) * 180.0 / KARVIS_PI);
                    camRot.yaw = rawYaw - 180.0f;
                    while (camRot.yaw > 180.0f) camRot.yaw -= 360.0f;
                    while (camRot.yaw < -180.0f) camRot.yaw += 360.0f;
                    gotRot = true;
                }
            }
            env->DeleteLocalRef(mvBuf);
        }
    }
    if (activeRenderInfoClass && field_ariProjection) {
        jobject prjBuf = env->GetStaticObjectField(activeRenderInfoClass, field_ariProjection);
        if (prjBuf) {
            float* prj = (float*)env->GetDirectBufferAddress(prjBuf);
            if (prj) {
                float focalY = prj[5];
                if (focalY > 0.01f) {
                    memcpy(localProj, prj, 16 * sizeof(float));
                    if (gotRot) matricesOK = true;
                    float fov = (float)(2.0 * atan(1.0 / (double)focalY) * 180.0 / KARVIS_PI);
                    if (fov > 1.0f && fov < 179.0f) { camFov = fov; gotFov = true; }
                }
            }
            env->DeleteLocalRef(prjBuf);
        }
    }

    if (!gotRot) {
        camRot.yaw = env->GetFloatField(player, field_rotationYaw);
        camRot.pitch = env->GetFloatField(player, field_rotationPitch);
    }
    if (!gotFov) camFov = GetFOV();

    env->DeleteLocalRef(player);

    if (g_espCSReady) {
        EnterCriticalSection(&g_espCS);
        g_espCam.camPos = camPos;
        g_espCam.camRot = camRot;
        g_espCam.camFov = camFov;
        g_espCam.partialTicks = pt;
        g_espCam.renderPos = renderPos;
        if (matricesOK) {
            memcpy(g_espCam.mvMatrix, localMV, sizeof(g_espCam.mvMatrix));
            memcpy(g_espCam.projMatrix, localProj, sizeof(g_espCam.projMatrix));
        }
        g_espCam.matricesValid = matricesOK;
        g_espCam.valid = true;
        LeaveCriticalSection(&g_espCS);
    }
}

void Java::CollectEspEntities(std::vector<EspEntityData>& out) {
    out.clear();
    if (!env || !listClass || !field_loadedEntityList || !entityClass ||
        !field_posX || !field_posY || !field_posZ) return;

    jobject mc = GetMinecraft();
    if (!mc) return;
    jobject world = env->GetObjectField(mc, field_theWorld);
    jobject thePlayer = field_thePlayer ? env->GetObjectField(mc, field_thePlayer) : nullptr;
    env->DeleteLocalRef(mc);
    if (!world) { if (thePlayer) env->DeleteLocalRef(thePlayer); return; }

    jobject list = env->GetObjectField(world, field_loadedEntityList);
    env->DeleteLocalRef(world);
    if (!list) { if (thePlayer) env->DeleteLocalRef(thePlayer); return; }

    jint size = env->CallIntMethod(list, method_list_size);
    if (env->ExceptionCheck()) { env->ExceptionClear(); env->DeleteLocalRef(list); if (thePlayer) env->DeleteLocalRef(thePlayer); return; }
    if (size > 512) size = 512;

    out.reserve((size_t)size);
    for (jint i = 0; i < size; i++) {
        jobject e = env->CallObjectMethod(list, method_list_get, i);
        if (env->ExceptionCheck()) { env->ExceptionClear(); continue; }
        if (!e) continue;

        if (thePlayer && env->IsSameObject(e, thePlayer)) { env->DeleteLocalRef(e); continue; }
        if (armorStandClass && env->IsInstanceOf(e, armorStandClass)) { env->DeleteLocalRef(e); continue; }

        bool isLiving = (entityLivingClass && env->IsInstanceOf(e, entityLivingClass));
        if (env->ExceptionCheck()) { env->ExceptionClear(); isLiving = false; }
        bool isPlayer = (entityPlayerClass && env->IsInstanceOf(e, entityPlayerClass));
        if (env->ExceptionCheck()) { env->ExceptionClear(); isPlayer = false; }
        if (!isLiving || !isPlayer) { env->DeleteLocalRef(e); continue; }

        EspEntityData ed;
        ed.x = (float)env->GetDoubleField(e, field_posX);
        ed.y = (float)env->GetDoubleField(e, field_posY);
        ed.z = (float)env->GetDoubleField(e, field_posZ);
        ed.isPlayer = true;
        ed.isRealPlayer = true;
        ed.isDead = field_isDead ? env->GetBooleanField(e, field_isDead) : false;
        if (env->ExceptionCheck()) { env->ExceptionClear(); ed.isDead = false; }
        ed.height = field_height ? env->GetFloatField(e, field_height) : 1.8f;
        if (env->ExceptionCheck()) { env->ExceptionClear(); ed.height = 1.8f; }
        if (ed.height < 0.1f || ed.height > 10.0f) ed.height = 1.8f;

        if (method_getHealth) {
            ed.health = env->CallFloatMethod(e, method_getHealth);
            if (env->ExceptionCheck()) { env->ExceptionClear(); ed.health = 0.f; }
        }
        if (method_getMaxHealth) {
            ed.maxHealth = env->CallFloatMethod(e, method_getMaxHealth);
            if (env->ExceptionCheck()) { env->ExceptionClear(); ed.maxHealth = 20.f; }
        }
        if (method_getAbsorption) {
            ed.absorption = env->CallFloatMethod(e, method_getAbsorption);
            if (env->ExceptionCheck()) { env->ExceptionClear(); ed.absorption = 0.f; }
        }

        if (method_getName) {
            jstring jn = (jstring)env->CallObjectMethod(e, method_getName);
            if (env->ExceptionCheck()) { env->ExceptionClear(); jn = nullptr; }
            if (jn) {
                const char* u = env->GetStringUTFChars(jn, nullptr);
                if (u) ed.name = u;
                if (u) env->ReleaseStringUTFChars(jn, u);
                env->DeleteLocalRef(jn);
            }
        }

        if (!ed.name.empty()) {
            std::string lower = ed.name;
            for (auto& c : lower) c = (char)tolower((unsigned char)c);
            if (lower.find("npc") != std::string::npos || lower.find("cit-") != std::string::npos) { env->DeleteLocalRef(e); continue; }
            if (ed.name.size() < 3 || ed.name.size() > 16) { env->DeleteLocalRef(e); continue; }
            bool validChars = true;
            for (size_t j = 0; j < ed.name.size() && validChars; j++) {
                char c = ed.name[j];
                if (!((c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z') || (c >= '0' && c <= '9') || c == '_')) validChars = false;
            }
            if (!validChars) { env->DeleteLocalRef(e); continue; }
        }

        if (!ed.isDead && ed.health > 0) out.push_back(ed);
        env->DeleteLocalRef(e);
    }

    if (thePlayer) env->DeleteLocalRef(thePlayer);
    env->DeleteLocalRef(list);
}


