LRESULT CALLBACK LowLevelMouseProc(int nCode, WPARAM wParam, LPARAM lParam) {
    return CallNextHookEx(g_mouseHook, nCode, wParam, lParam);
}

LRESULT CALLBACK LowLevelKeyboardProc(int nCode, WPARAM wParam, LPARAM lParam) {
    if (nCode >= 0) {
        KBDLLHOOKSTRUCT* kb = (KBDLLHOOKSTRUCT*)lParam;
        if (kb->vkCode == VK_F11 && (wParam == WM_KEYDOWN || wParam == WM_SYSKEYDOWN)) {
            if (!(kb->flags & LLKHF_INJECTED)) {
                g_f11Pressed = true;
                return 1;
            }
        }
    }
    return CallNextHookEx(g_keyboardHook, nCode, wParam, lParam);
}

// ===================== BORDERLESS FULLSCREEN =====================
static HWND FindGameWindow() {
    HWND hw = FindWindowA("LWJGL", nullptr);
    if (!hw) hw = FindWindowA("GLFW30", nullptr);
    if (!hw) hw = FindWindowA(nullptr, "Minecraft");
    if (!hw) hw = FindWindowA("SunAwtFrame", nullptr);
    return hw;
}

static bool IsMinecraftForegroundWindow(HWND mcWnd) {
    if (!mcWnd || !IsWindow(mcWnd)) return false;
    HWND fg = GetForegroundWindow();
    if (!fg) return false;
    return (fg == mcWnd) || IsChild(mcWnd, fg);
}

static bool IsCursorInsideWindow(HWND wnd) {
    if (!wnd || !IsWindow(wnd)) return false;
    POINT pt;
    if (!GetCursorPos(&pt)) return false;
    RECT r;
    if (!GetWindowRect(wnd, &r)) return false;
    return PtInRect(&r, pt) != 0;
}

static void ToggleBorderlessFullscreen(HWND game) {
    if (!game) return;
    HMONITOR hMon = MonitorFromWindow(game, MONITOR_DEFAULTTONEAREST);
    MONITORINFO mi = { sizeof(MONITORINFO) };
    GetMonitorInfo(hMon, &mi);
    if (!g_borderlessFS) {
        g_savedGameStyle = (DWORD)GetWindowLongA(game, GWL_STYLE);
        GetWindowRect(game, &g_savedGameRect);
        DWORD ns = g_savedGameStyle & ~(WS_CAPTION | WS_THICKFRAME | WS_BORDER |
            WS_DLGFRAME | WS_SYSMENU | WS_MINIMIZEBOX | WS_MAXIMIZEBOX);
        SetWindowLongA(game, GWL_STYLE, (LONG)ns);
        SetWindowPos(game, HWND_TOP,
            mi.rcMonitor.left, mi.rcMonitor.top,
            mi.rcMonitor.right - mi.rcMonitor.left,
            mi.rcMonitor.bottom - mi.rcMonitor.top,
            SWP_FRAMECHANGED | SWP_NOACTIVATE);
        g_borderlessFS = true;
        Log("Borderless fullscreen ON");
    }
    else {
        SetWindowLongA(game, GWL_STYLE, (LONG)g_savedGameStyle);
        SetWindowPos(game, HWND_TOP,
            g_savedGameRect.left, g_savedGameRect.top,
            g_savedGameRect.right - g_savedGameRect.left,
            g_savedGameRect.bottom - g_savedGameRect.top,
            SWP_FRAMECHANGED | SWP_NOACTIVATE);
        g_borderlessFS = false;
        Log("Borderless fullscreen OFF");
    }
}

// ===================== JNI HELPERS =====================
static jfieldID TryGetField(JNIEnv* env, jclass cls, const char** names, const char* sig) {
    if (!env || !cls) return nullptr;
    for (int i = 0; names[i]; i++) {
        jfieldID f = env->GetFieldID(cls, names[i], sig);
        if (f && !env->ExceptionCheck()) return f;
        env->ExceptionClear();
    }
    return nullptr;
}

static jmethodID TryGetMethod(JNIEnv* env, jclass cls, const char** names, const char* sig) {
    if (!env || !cls) return nullptr;
    for (int i = 0; names[i]; i++) {
        jmethodID m = env->GetMethodID(cls, names[i], sig);
        if (m && !env->ExceptionCheck()) return m;
        env->ExceptionClear();
    }
    return nullptr;
}

