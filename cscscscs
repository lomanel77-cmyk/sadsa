static int MapPixelSize() {
    switch (g_settings.mapSize) {
    case 0: return 140;   // Small
    case 1: return 180;   // Medium
    case 2: return 224;   // Large
    case 3: return 288;   // X-Large
    case 4: return 360;   // XX-Large
    case 5: return 440;   // Huge
    default: return 224;
    }
}

static int MapBlocksPerPixelMul10() {
    // zoom 1..5 -> blocks-per-pixel: 1.6, 1.2, 0.9, 0.6, 0.4
    switch (g_settings.mapZoom) {
    case 1: return 16;
    case 2: return 12;
    case 3: return 9;
    case 4: return 6;
    case 5: return 4;
    default: return 12;
    }
}

// Smooth a sample color based on flags (highlight ore, dim caves)
static COLORREF ApplyFlagsTint(COLORREF c, uint8_t flags) {
    int r = GetRValue(c), g = GetGValue(c), b = GetBValue(c);
    if (flags & 1) { // ore: boost saturation / brighten
        r = min(255, r + 30);
        g = min(255, g + 30);
        b = min(255, b + 30);
    }
    if (flags & 2) { // cave
        r = r * 3 / 5; g = g * 3 / 5; b = b * 3 / 5;
    }
    return RGB(r, g, b);
}

static void DrawPlayerArrow(HDC hdc, int cx, int cy, float yawDeg, COLORREF fill, COLORREF outline) {
    float yaw = yawDeg * 3.14159265f / 180.0f;
    float s = sinf(yaw), co = cosf(yaw);
    POINT pts[3];
    auto tr = [&](float fx, float fy, int idx) {
        float rx = fx * co - fy * s;
        float ry = fx * s + fy * co;
        pts[idx].x = cx + (int)rx;
        pts[idx].y = cy + (int)ry;
        };
    tr(0.0f, -7.0f, 0);
    tr(5.0f, 5.0f, 1);
    tr(-5.0f, 5.0f, 2);
    HBRUSH br = CreateSolidBrush(fill);
    HPEN pn = CreatePen(PS_SOLID, 2, outline);
    HBRUSH ob = (HBRUSH)SelectObject(hdc, br);
    HPEN op = (HPEN)SelectObject(hdc, pn);
    Polygon(hdc, pts, 3);
    SelectObject(hdc, ob); SelectObject(hdc, op);
    DeleteObject(br); DeleteObject(pn);
}

// Deterministic name hash
static uint32_t NameHash(const char* s) {
    uint32_t h = 2166136261u;
    if (!s) return h;
    for (const unsigned char* p = (const unsigned char*)s; *p; p++) {
        h ^= *p;
        h *= 16777619u;
    }
    return h;
}

// Build an 8x8 pixel-art Minecraft-style head into the given buffer (row-major BGRA).
// Generates skin/hair/eye variations deterministically from the player name hash.
static void BuildHeadPixels(const char* name, uint32_t pixels[64]) {
    uint32_t h = NameHash(name);

    // Skin palette (Minecraft-ish Steve-to-variant tones)
    static const COLORREF skinPalette[8] = {
        RGB(251, 224, 196), // very pale
        RGB(244, 205, 168), // light
        RGB(227, 183, 141), // Steve default-ish
        RGB(200, 151, 110), // tan
        RGB(170, 124, 87),  // medium
        RGB(135, 92, 61),   // brown
        RGB(96,  64, 42),   // dark brown
        RGB(70,  45, 28),   // very dark
    };
    // Hair palette
    static const COLORREF hairPalette[8] = {
        RGB(35, 25, 20),    // near-black
        RGB(58, 38, 22),    // dark brown (Steve)
        RGB(92, 57, 32),    // brown
        RGB(140, 92, 45),   // medium brown
        RGB(190, 140, 70),  // dirty blonde
        RGB(230, 200, 110), // blonde
        RGB(170, 50, 40),   // red/ginger
        RGB(150, 150, 160), // silver/gray
    };

    int skinIdx = (h >> 2) & 7;
    int hairIdx = (h >> 6) & 7;
    int hairStyle = (h >> 10) & 3;   // 0..3 different hair patterns
    int eyeTone = (h >> 14) & 3;     // 0..3 eye variations
    bool mouthSmile = ((h >> 16) & 1) != 0;

    COLORREF skin = skinPalette[skinIdx];
    COLORREF hair = hairPalette[hairIdx];

    // Shade helpers
    auto shade = [](COLORREF c, int delta) -> COLORREF {
        int r = (int)GetRValue(c) + delta; if (r < 0) r = 0; if (r > 255) r = 255;
        int g = (int)GetGValue(c) + delta; if (g < 0) g = 0; if (g > 255) g = 255;
        int b = (int)GetBValue(c) + delta; if (b < 0) b = 0; if (b > 255) b = 255;
        return RGB(r, g, b);
        };

    COLORREF skinDark = shade(skin, -22);
    COLORREF skinLight = shade(skin, 12);
    COLORREF hairDark = shade(hair, -18);

    static const COLORREF eyeColors[4] = {
        RGB(60, 45, 30),    // brown
        RGB(40, 80, 160),   // blue
        RGB(50, 110, 60),   // green
        RGB(100, 70, 40),   // hazel
    };
    COLORREF eye = eyeColors[eyeTone];

    // Template (8 rows x 8 cols). Chars:
    //   H=hair, h=hairDark, S=skin, s=skinDark, l=skinLight, E=eye, M=mouth(skinDark), .=skin
    static const char* styles[4][8] = {
        // Style 0 - classic short
        {
            "HHHHHHHH",
            "HHHHHHHH",
            "HhhhhhhH",
            "SSESSESS",
            "SSSSSSSS",
            "SSMMMMSS",
            "SSSSSSSS",
            "SssSSssS",
        },
        // Style 1 - longer hair / fringe
        {
            "HHHHHHHH",
            "HHHHHHHH",
            "HHHhhhHH",
            "HSESSESH",
            "SSSSSSSS",
            "SSMMMMSS",
            "SSSSSSSS",
            "sSSSSSSs",
        },
        // Style 2 - messy bangs
        {
            "hHHhHHhh",
            "HHHHHHHH",
            "HhhhhhhH",
            "SSESSESS",
            "SSSSSSSS",
            "SSsMMsSS",
            "SSSSSSSS",
            "sSSssSSs",
        },
        // Style 3 - tight / skin-showing
        {
            "sHHHHHHs",
            "HHHHHHHH",
            "SSSSSSSS",
            "SSESSESS",
            "SSSSSSSS",
            "SSMMMMSS",
            "SSSSSSSS",
            "SSSSSSSS",
        },
    };

    const char* const* tmpl = styles[hairStyle];

    for (int y = 0; y < 8; y++) {
        for (int x = 0; x < 8; x++) {
            char c = tmpl[y][x];
            COLORREF px;
            switch (c) {
            case 'H': px = hair; break;
            case 'h': px = hairDark; break;
            case 'S': px = skin; break;
            case 's': px = skinDark; break;
            case 'l': px = skinLight; break;
            case 'E': px = eye; break;
            case 'M': px = mouthSmile ? shade(skin, -45) : shade(skin, -30); break;
            default:  px = skin; break;
            }
            // BGRA 32-bit
            uint8_t r = GetRValue(px), g = GetGValue(px), b = GetBValue(px);
            pixels[y * 8 + x] = (uint32_t)(0xFFu << 24) | ((uint32_t)r << 16) | ((uint32_t)g << 8) | b;
        }
    }
}

static void DrawPlayerHead(HDC hdc, int cx, int cy, int pixelSize, const char* name) {
    // pixelSize = target drawing size (e.g. 14..22 depending on map zoom)
    if (pixelSize < 10) pixelSize = 10;
    if (pixelSize > 40) pixelSize = 40;

    uint32_t head[64];
    BuildHeadPixels(name ? name : "", head);

    BITMAPINFO bi = {};
    bi.bmiHeader.biSize = sizeof(BITMAPINFOHEADER);
    bi.bmiHeader.biWidth = 8;
    bi.bmiHeader.biHeight = -8;       // top-down
    bi.bmiHeader.biPlanes = 1;
    bi.bmiHeader.biBitCount = 32;
    bi.bmiHeader.biCompression = BI_RGB;

    int dx = cx - pixelSize / 2;
    int dy = cy - pixelSize / 2;

    // Drop shadow behind head
    HBRUSH shBr = CreateSolidBrush(RGB(0, 0, 0));
    RECT sh = { dx + 1, dy + 1, dx + pixelSize + 1, dy + pixelSize + 1 };
    FillRect(hdc, &sh, shBr);
    DeleteObject(shBr);

    int oldMode = SetStretchBltMode(hdc, COLORONCOLOR); // nearest-neighbor - keeps pixel art crisp
    StretchDIBits(hdc, dx, dy, pixelSize, pixelSize,
        0, 0, 8, 8, head, &bi, DIB_RGB_COLORS, SRCCOPY);
    SetStretchBltMode(hdc, oldMode);

    // Thin outline
    HPEN pn = CreatePen(PS_SOLID, 1, RGB(0, 0, 0));
    HPEN op = (HPEN)SelectObject(hdc, pn);
    HBRUSH ob = (HBRUSH)SelectObject(hdc, GetStockObject(NULL_BRUSH));
    Rectangle(hdc, dx - 1, dy - 1, dx + pixelSize + 1, dy + pixelSize + 1);
    SelectObject(hdc, op); SelectObject(hdc, ob);
    DeleteObject(pn);
}

static void DrawMapDot(HDC hdc, int cx, int cy, COLORREF color, int r) {
    HBRUSH br = CreateSolidBrush(color);
    HPEN pn = CreatePen(PS_SOLID, 1, RGB(0, 0, 0));
    HBRUSH ob = (HBRUSH)SelectObject(hdc, br);
    HPEN op = (HPEN)SelectObject(hdc, pn);
    Ellipse(hdc, cx - r, cy - r, cx + r + 1, cy + r + 1);
    SelectObject(hdc, ob); SelectObject(hdc, op);
    DeleteObject(br); DeleteObject(pn);
}

// Draws a simple steel-tinted cap on top of a player head to indicate a helmet.
// The head quad is [cx - size/2, cy - size/2] .. [cx + size/2, cy + size/2].
static void DrawHelmetOverlay(HDC hdc, int cx, int cy, int size) {
    int half = size / 2;
    int left = cx - half, top = cy - half;
    int capH = size / 3; if (capH < 4) capH = 4;

    // Cap body
    HBRUSH cb = CreateSolidBrush(RGB(170, 175, 185));
    RECT cr = { left - 1, top - 2, left + size + 1, top + capH };
    FillRect(hdc, &cr, cb);
    DeleteObject(cb);

    // Highlight strip
    HBRUSH hi = CreateSolidBrush(RGB(215, 220, 230));
    RECT hr = { left - 1, top - 2, left + size + 1, top - 1 };
    FillRect(hdc, &hr, hi);
    DeleteObject(hi);

    // Side flaps coming down over the ears
    HBRUSH fb = CreateSolidBrush(RGB(135, 140, 150));
    RECT lf = { left - 2, top + capH - 1, left + 1, top + capH + 3 };
    RECT rf = { left + size - 1, top + capH - 1, left + size + 2, top + capH + 3 };
    FillRect(hdc, &lf, fb);
    FillRect(hdc, &rf, fb);
    DeleteObject(fb);

    // Thin outline
    HPEN pn = CreatePen(PS_SOLID, 1, RGB(0, 0, 0));
    HPEN op = (HPEN)SelectObject(hdc, pn);
    HBRUSH ob = (HBRUSH)SelectObject(hdc, GetStockObject(NULL_BRUSH));
    Rectangle(hdc, left - 2, top - 3, left + size + 2, top + capH + 1);
    SelectObject(hdc, op); SelectObject(hdc, ob);
    DeleteObject(pn);
}

// Minecraft-style HP bar above a head. Draws one row of red hearts for
// `health` (each heart = 2 HP, max 10 per row), then a row of gold hearts
// for `absorption` immediately above. Each heart is a tiny filled lobe +
// triangle shape that reads as a heart at minimap scale.
static void DrawHeart(HDC hdc, int x, int y, int sz, COLORREF fill, COLORREF dark) {
    // Two filled lobes on top + downward triangle = heart shape.
    HBRUSH br = CreateSolidBrush(fill);
    HPEN   pn = CreatePen(PS_SOLID, 1, dark);
    HBRUSH ob = (HBRUSH)SelectObject(hdc, br);
    HPEN   op = (HPEN)SelectObject(hdc, pn);

    int lobeR = sz / 3;
    if (lobeR < 2) lobeR = 2;
    Ellipse(hdc, x, y, x + 2 * lobeR, y + 2 * lobeR);
    Ellipse(hdc, x + sz - 2 * lobeR, y, x + sz, y + 2 * lobeR);
    POINT tri[3] = {
        { x,          y + lobeR },
        { x + sz - 1, y + lobeR },
        { x + sz / 2, y + sz    }
    };
    Polygon(hdc, tri, 3);

    SelectObject(hdc, op);
    SelectObject(hdc, ob);
    DeleteObject(pn);
    DeleteObject(br);
}

static void DrawHeartRow(HDC hdc, int cx, int topY, int count, bool absorption) {
    if (count <= 0) return;
    if (count > 10) count = 10;
    int sz = 6;
    int gap = 1;
    int rowW = count * sz + (count - 1) * gap;
    int x = cx - rowW / 2;
    COLORREF fill = absorption ? RGB(252, 204, 64) : RGB(230, 40, 50);
    COLORREF dark = absorption ? RGB(90, 66, 12) : RGB(80, 0, 0);
    for (int i = 0; i < count; i++) DrawHeart(hdc, x + i * (sz + gap), topY, sz, fill, dark);
}

static void DrawHeartStack(HDC hdc, int cx, int baseY, int redHearts, int goldHearts) {
    int row = 0;
    while (redHearts > 0) {
        int n = redHearts > 10 ? 10 : redHearts;
        DrawHeartRow(hdc, cx, baseY - row * 8, n, false);
        redHearts -= n;
        row++;
    }
    while (goldHearts > 0) {
        int n = goldHearts > 10 ? 10 : goldHearts;
        DrawHeartRow(hdc, cx, baseY - row * 8, n, true);
        goldHearts -= n;
        row++;
    }
}

static void RenderMinimapTo(HDC hdc, int mapW, int mapH) {
    // Ensure backbuffer
    if (!g_mapMemDC || g_mapBmpW != mapW || g_mapBmpH != mapH) {
        if (g_mapBmp) { DeleteObject(g_mapBmp); g_mapBmp = nullptr; }
        if (g_mapMemDC) { DeleteDC(g_mapMemDC); g_mapMemDC = nullptr; }
        g_mapMemDC = CreateCompatibleDC(hdc);
        g_mapBmp = CreateCompatibleBitmap(hdc, mapW, mapH);
        SelectObject(g_mapMemDC, g_mapBmp);
        g_mapBmpW = mapW;
        g_mapBmpH = mapH;
    }
    HDC dc = g_mapMemDC;

    // Use color key transparent color (magenta) outside clip
    HBRUSH clear = CreateSolidBrush(RGB(255, 0, 255));
    RECT clearR = { 0, 0, mapW, mapH };
    FillRect(dc, &clearR, clear);
    DeleteObject(clear);

    // Clip region (round or square)
    HRGN clipRgn = nullptr;
    if (g_settings.mapRound) clipRgn = CreateEllipticRgn(2, 2, mapW - 2, mapH - 2);
    else clipRgn = CreateRoundRectRgn(2, 2, mapW - 1, mapH - 1, 8, 8);
    SelectClipRgn(dc, clipRgn);

    // Paint BG inside clip
    HBRUSH bgBr = CreateSolidBrush(RGB(18, 22, 28));
    FillRgn(dc, clipRgn, bgBr);
    DeleteObject(bgBr);

    MapData snap;
    if (g_mapCSReady) {
        EnterCriticalSection(&g_mapCS);
        snap.centerBlockX = g_map.centerBlockX;
        snap.centerBlockZ = g_map.centerBlockZ;
        snap.playerX = g_map.playerX;
        snap.playerY = g_map.playerY;
        snap.playerZ = g_map.playerZ;
        snap.playerYaw = g_map.playerYaw;
        snap.underground = g_map.underground;
        snap.valid = g_map.valid;
        memcpy(snap.samples, g_map.samples, sizeof(g_map.samples));
        snap.entities = g_map.entities;
        LeaveCriticalSection(&g_mapCS);
    }

    if (snap.valid) {
        // Compose a small DIB from samples and stretch-blit to fit mapW/mapH
        BITMAPINFO bi = {};
        bi.bmiHeader.biSize = sizeof(BITMAPINFOHEADER);
        bi.bmiHeader.biWidth = TERRAIN_DIM;
        bi.bmiHeader.biHeight = -TERRAIN_DIM; // top-down
        bi.bmiHeader.biPlanes = 1;
        bi.bmiHeader.biBitCount = 32;
        bi.bmiHeader.biCompression = BI_RGB;

        static std::vector<uint32_t> buf(TERRAIN_DIM * TERRAIN_DIM);
        // BG color used for tiles we haven't sampled yet (during progressive
        // load). Matches the minimap background so unsampled rows blend in
        // seamlessly instead of appearing as solid black strips.
        const uint32_t UNSAMPLED = 0xFF12161Cu; // 0xAARRGGBB = RGB(18,22,28)
        for (int y = 0; y < TERRAIN_DIM; y++) {
            for (int x = 0; x < TERRAIN_DIM; x++) {
                const MapSample& s = snap.samples[y * TERRAIN_DIM + x];
                // yTop == 0 and no flags means the tile has never been sampled.
                if (s.yTop == 0 && s.color == 0 && s.flags == 0) {
                    buf[y * TERRAIN_DIM + x] = UNSAMPLED;
                    continue;
                }
                COLORREF c = ApplyFlagsTint(s.color, s.flags);
                // add simple shading based on height difference vs north neighbor
                int yn = y > 0 ? snap.samples[(y - 1) * TERRAIN_DIM + x].yTop : s.yTop;
                int dy = s.yTop - yn;
                int r = GetRValue(c), g = GetGValue(c), b = GetBValue(c);
                if (dy > 0) { r = min(255, r + 18); g = min(255, g + 18); b = min(255, b + 18); }
                else if (dy < 0) { r = max(0, r - 18); g = max(0, g - 18); b = max(0, b - 18); }
                buf[y * TERRAIN_DIM + x] = (uint32_t)(0xFF000000u | ((uint32_t)r << 16) | ((uint32_t)g << 8) | (uint32_t)b);
            }
        }

        // Compute scale: terrain covers TERRAIN_DIM*BPP blocks. Render so player stays centered.
        // Player offset within the grid (since centerBlockX is sample (64,64))
        float subX = snap.playerX - (float)snap.centerBlockX;
        float subZ = snap.playerZ - (float)snap.centerBlockZ;
        float bpp = MapBlocksPerPixelMul10() / 10.0f;
        int terrainPx = (int)(TERRAIN_DIM / bpp);
        int subPxX = (int)(subX / bpp);
        int subPxZ = (int)(subZ / bpp);

        int destX = (mapW / 2) - (terrainPx / 2) - subPxX;
        int destY = (mapH / 2) - (terrainPx / 2) - subPxZ;

        SetStretchBltMode(dc, HALFTONE);
        SetBrushOrgEx(dc, 0, 0, nullptr);
        StretchDIBits(dc, destX, destY, terrainPx, terrainPx,
            0, 0, TERRAIN_DIM, TERRAIN_DIM, buf.data(), &bi, DIB_RGB_COLORS, SRCCOPY);

        // Entities
        if (g_settings.mapShowEntities) {
            // Head size scales with map size for readability
            int headSz = mapW / 14;
            if (headSz < 12) headSz = 12;
            if (headSz > 24) headSz = 24;

            for (const auto& e : snap.entities) {
                // Never draw the local player - only the center arrow represents us.
                if (e.isSelf) continue;
                // Drop every non-real-player entity: fake EntityPlayer bots
                // (named NPCs on servers like Hypixel lobbies), passive mobs
                // and item / xp-orb / other entities. The minimap now only
                // displays actual connected players and hostile mobs.
                if (e.kind == 1 && !e.isRealPlayer) continue;
                if (e.isNpc) continue;
                if (e.kind == 3) continue; // passive mobs (villagers, cows ...)
                if (e.kind == 4) continue; // items, xp orbs, arrows, etc.

                float ex = (e.x - snap.playerX) / bpp;
                float ez = (e.z - snap.playerZ) / bpp;
                int ix = (int)(mapW / 2 + ex);
                int iy = (int)(mapH / 2 + ez);
                int margin = headSz / 2 + 2;
                if (ix < margin || ix > mapW - margin || iy < margin || iy > mapH - margin) continue;

                if (e.kind == 1 && g_settings.mapShowHeads) {
                    DrawPlayerHead(dc, ix, iy, headSz, e.name);
                    if (e.hasHelmet) DrawHelmetOverlay(dc, ix, iy, headSz);

                    if (g_settings.mapShowNames && e.name[0]) {
                        SelectObject(dc, g_mapFont);
                        SetBkMode(dc, TRANSPARENT);
                        int tagY = iy + headSz / 2 + 2;
                        RECT tr = { ix - 50, tagY, ix + 50, tagY + 14 };
                        RECT tsh = { tr.left + 1, tr.top + 1, tr.right + 1, tr.bottom + 1 };
                        SetTextColor(dc, RGB(0, 0, 0));
                        DrawTextA(dc, e.name, -1, &tsh, DT_CENTER | DT_SINGLELINE | DT_TOP | DT_NOPREFIX);
                        SetTextColor(dc, RGB(245, 248, 255));
                        DrawTextA(dc, e.name, -1, &tr, DT_CENTER | DT_SINGLELINE | DT_TOP | DT_NOPREFIX);
                    }
                }
                else if (e.kind == 1) {
                    DrawMapDot(dc, ix, iy, RGB(90, 200, 255), 4);
                }
                else if (e.kind == 2) {
                    DrawMapDot(dc, ix, iy, RGB(230, 60, 60), 4);
                }
                else if (e.kind == 3) {
                    DrawMapDot(dc, ix, iy, RGB(90, 200, 90), 3);
                }
                else {
                    DrawMapDot(dc, ix, iy, RGB(210, 210, 80), 2);
                }
            }
        }

        // Self - arrow at center pointing yaw
        DrawPlayerArrow(dc, mapW / 2, mapH / 2, snap.playerYaw + 180.0f, RGB(255, 255, 255), RGB(0, 0, 0));
    }
    else {
        SelectObject(dc, g_mapFont);
        SetBkMode(dc, TRANSPARENT);
        SetTextColor(dc, RGB(180, 180, 200));
        RECT tr = { 0, mapH / 2 - 8, mapW, mapH / 2 + 8 };
        DrawTextA(dc, "Loading...", -1, &tr, DT_CENTER | DT_SINGLELINE | DT_VCENTER);
    }

    // Reset clip for border / UI
    SelectClipRgn(dc, nullptr);

    // Border
    HPEN bPen = CreatePen(PS_SOLID, 2, RGB(100, 200, 255));
    HPEN op = (HPEN)SelectObject(dc, bPen);
    HBRUSH ob = (HBRUSH)SelectObject(dc, GetStockObject(NULL_BRUSH));
    if (g_settings.mapRound) Ellipse(dc, 2, 2, mapW - 2, mapH - 2);
    else RoundRect(dc, 2, 2, mapW - 1, mapH - 1, 8, 8);
    SelectObject(dc, op); SelectObject(dc, ob);
    DeleteObject(bPen);

    // Cardinal N
    SelectObject(dc, g_mapFontBold);
    SetBkMode(dc, TRANSPARENT);
    SetTextColor(dc, RGB(0, 0, 0));
    RECT nsh = { mapW / 2 - 8, 4, mapW / 2 + 8, 20 };
    DrawTextA(dc, "N", -1, &nsh, DT_CENTER | DT_SINGLELINE | DT_VCENTER);
    nsh.left++; nsh.top++; nsh.right++; nsh.bottom++;
    SetTextColor(dc, RGB(255, 80, 80));
    RECT nR = { mapW / 2 - 8, 3, mapW / 2 + 8, 19 };
    DrawTextA(dc, "N", -1, &nR, DT_CENTER | DT_SINGLELINE | DT_VCENTER);

    DeleteObject(clipRgn);

    // Blit to target hdc
    BitBlt(hdc, 0, 0, mapW, mapH, g_mapMemDC, 0, 0, SRCCOPY);
}

LRESULT CALLBACK MapWndProc(HWND hWnd, UINT msg, WPARAM wParam, LPARAM lParam) {
    switch (msg) {
    case WM_CREATE:
        SetTimer(hWnd, 2, 33, nullptr);
        return 0;
    case WM_TIMER:
        InvalidateRect(hWnd, nullptr, FALSE);
        return 0;
    case WM_ERASEBKGND:
        return TRUE;
    case WM_PAINT: {
        PAINTSTRUCT ps;
        HDC hdc = BeginPaint(hWnd, &ps);
        RECT cr; GetClientRect(hWnd, &cr);
        RenderMinimapTo(hdc, cr.right, cr.bottom);
        EndPaint(hWnd, &ps);
        return 0;
    }
    case WM_MOUSEACTIVATE:
        return MA_NOACTIVATE;
    case WM_DESTROY:
        KillTimer(hWnd, 2);
        if (g_mapBmp) { DeleteObject(g_mapBmp); g_mapBmp = nullptr; }
        if (g_mapMemDC) { DeleteDC(g_mapMemDC); g_mapMemDC = nullptr; }
        g_mapBmpW = g_mapBmpH = 0;
        return 0;
    }
    return DefWindowProc(hWnd, msg, wParam, lParam);
}

static void PositionMapWindow() {
    if (!g_mapWnd) return;
    int sz = MapPixelSize();
    HWND game = FindGameWindow();
    RECT gr = {};
    if (game && GetClientRect(game, &gr)) {
        POINT tl = { gr.left, gr.top };
        ClientToScreen(game, &tl);
        int w = gr.right - gr.left;
        int h = gr.bottom - gr.top;
        int pad = 10;
        int x = tl.x + pad, y = tl.y + pad;
        switch (g_settings.mapCorner) {
        case 0: x = tl.x + w - sz - pad; y = tl.y + pad; break;               // TR
        case 1: x = tl.x + pad;          y = tl.y + pad; break;               // TL
        case 2: x = tl.x + w - sz - pad; y = tl.y + h - sz - pad; break;      // BR
        case 3: x = tl.x + pad;          y = tl.y + h - sz - pad; break;      // BL
        }
        SetWindowPos(g_mapWnd, HWND_TOPMOST, x, y, sz, sz, SWP_NOACTIVATE | SWP_SHOWWINDOW);
    }
    else {
        int scrW = GetSystemMetrics(SM_CXSCREEN);
        int x = scrW - sz - 20, y = 20;
        SetWindowPos(g_mapWnd, HWND_TOPMOST, x, y, sz, sz, SWP_NOACTIVATE | SWP_SHOWWINDOW);
    }
}

DWORD WINAPI MapWindowThread(LPVOID param) {
    HINSTANCE hInst = (HINSTANCE)param;
    static bool reg = false;
    if (!reg) {
        WNDCLASSEXA wc = {};
        wc.cbSize = sizeof(wc);
        wc.lpfnWndProc = MapWndProc;
        wc.hInstance = hInst;
        wc.hbrBackground = CreateSolidBrush(RGB(255, 0, 255));
        wc.hCursor = LoadCursor(nullptr, IDC_ARROW);
        wc.lpszClassName = "KarvisMinimap";
        RegisterClassExA(&wc);
        reg = true;
    }
    g_mapFont = CreateFontA(11, 0, 0, 0, FW_SEMIBOLD, FALSE, FALSE, FALSE, DEFAULT_CHARSET, 0, 0, CLEARTYPE_QUALITY, DEFAULT_PITCH | FF_SWISS, "Segoe UI");
    g_mapFontBold = CreateFontA(13, 0, 0, 0, FW_BOLD, FALSE, FALSE, FALSE, DEFAULT_CHARSET, 0, 0, CLEARTYPE_QUALITY, DEFAULT_PITCH | FF_SWISS, "Segoe UI");

    int sz = MapPixelSize();
    g_mapWnd = CreateWindowExA(
        WS_EX_TOPMOST | WS_EX_TOOLWINDOW | WS_EX_LAYERED | WS_EX_TRANSPARENT | WS_EX_NOACTIVATE,
        "KarvisMinimap", "KarvisMap", WS_POPUP,
        20, 20, sz, sz, nullptr, nullptr, hInst, nullptr);
    if (!g_mapWnd) {
        Log("MAP: CreateWindow failed");
        return 1;
    }
    // Magenta (255,0,255) color-keyed as fully transparent
    SetLayeredWindowAttributes(g_mapWnd, RGB(255, 0, 255), (BYTE)g_settings.mapOpacity, LWA_COLORKEY | LWA_ALPHA);
    PositionMapWindow();

    MSG msg;
    g_mapRunning = true;
    ULONGLONG lastReposition = 0;
    BYTE lastOpacity = (BYTE)g_settings.mapOpacity;
    while (g_mapRunning) {
        while (PeekMessage(&msg, nullptr, 0, 0, PM_REMOVE)) {
            if (msg.message == WM_QUIT) { g_mapRunning = false; break; }
            TranslateMessage(&msg);
            DispatchMessage(&msg);
        }
        ULONGLONG now = GetTickCount64();
        if (now - lastReposition > 150) {
            lastReposition = now;

            // Tie minimap visibility to Minecraft: only show when MC is the active
            // foreground window and we're in a world.
            HWND game = FindGameWindow();
            HWND fg = GetForegroundWindow();

            bool mcAlive = game && IsWindow(game);
            bool mcShown = mcAlive && IsWindowVisible(game) && !IsIconic(game);
            bool mcForeground = mcAlive && (fg == game);
            bool shouldShow = g_settings.mapEnabled && g_inGame && mcShown && mcForeground;

            if (shouldShow) {
                // Sync opacity if user changed the setting
                BYTE o = (BYTE)g_settings.mapOpacity;
                if (o != lastOpacity) {
                    SetLayeredWindowAttributes(g_mapWnd, RGB(255, 0, 255), o, LWA_COLORKEY | LWA_ALPHA);
                    lastOpacity = o;
                }
                if (!IsWindowVisible(g_mapWnd)) ShowWindow(g_mapWnd, SW_SHOWNOACTIVATE);
                PositionMapWindow();
            }
            else {
                if (IsWindowVisible(g_mapWnd)) ShowWindow(g_mapWnd, SW_HIDE);
            }
        }
        Sleep(16);
    }

    if (g_mapWnd) { DestroyWindow(g_mapWnd); g_mapWnd = nullptr; }
    if (g_mapFont) { DeleteObject(g_mapFont); g_mapFont = nullptr; }
    if (g_mapFontBold) { DeleteObject(g_mapFontBold); g_mapFontBold = nullptr; }
    return 0;
}

// ===================== MINIMAP DATA UPDATER =====================
// Performance strategy:
//   - Work persists between calls in a staging buffer; each call processes a
//     small slice of rows (ROWS_PER_TICK) then returns control so the JNI
//     worker thread doesn't freeze for hundreds of ms.
//   - Top-down scan uses stride 4 first to find the approximate surface, then
//     refines within a small window. ~5x fewer JNI calls vs the naive scan.
//   - When the player moves, we recentre the grid and reuse overlapping
//     samples (scrolling buffer) so only the newly exposed rows/columns must
//     be resampled.

static MapSample g_stagingSamples[TERRAIN_DIM * TERRAIN_DIM];
static int  g_stagingCenterX = 0;
static int  g_stagingCenterZ = 0;
static bool g_stagingValid = false;
static int  g_stagingRowCursor = 0;   // next row index to sample (0..TERRAIN_DIM-1)
static bool g_stagingUnderground = false;
static int  g_stagingCenterY = 64;

static void SampleOneColumn(int bx, int bz, int centerY, bool underground, MapSample& out) {
    out.color = RGB(24, 28, 36);
    out.yTop = centerY;
    out.flags = 0;

    if (!underground) {
        // Coarse scan: step 4 from y=255 down until we hit something solid
        int approxY = -1;
        for (int y = 255; y >= 0; y -= 8) {
            uint8_t f;
            int c = Java::GetBlockColorAt(bx, y, bz, f);
            if (c < 0) continue;
            int r = GetRValue((COLORREF)c), g = GetGValue((COLORREF)c), b = GetBValue((COLORREF)c);
            if (r == 0 && g == 0 && b == 0) continue;
            approxY = y;
            break;
        }
        if (approxY < 0) return;

        // Refine: scan up to +8 above approxY to find the actual top
        int topY = approxY;
        int topC = -1;
        uint8_t topF = 0;
        for (int y = approxY + 8; y >= approxY - 4 && y >= 0; y--) {
            uint8_t f;
            int c = Java::GetBlockColorAt(bx, y, bz, f);
            if (c < 0) continue;
            int r = GetRValue((COLORREF)c), g = GetGValue((COLORREF)c), b = GetBValue((COLORREF)c);
            if (r == 0 && g == 0 && b == 0) continue;
            topC = c; topY = y; topF = f;
            break;
        }
        if (topC >= 0) {
            out.color = (COLORREF)topC;
            out.yTop = topY;
            out.flags = topF;
        }
    }
    else {
        int best = -1, bestY = centerY;
        uint8_t bestF = 0;
        int scanLo = centerY - 6; if (scanLo < 0) scanLo = 0;
        for (int y = centerY + 1; y >= scanLo; y--) {
            uint8_t f;
            int c = Java::GetBlockColorAt(bx, y, bz, f);
            if (c < 0) continue;
            int r = GetRValue((COLORREF)c), g = GetGValue((COLORREF)c), b = GetBValue((COLORREF)c);
            bool solid = !(r == 0 && g == 0 && b == 0);
            if (solid) {
                best = c; bestY = y; bestF = f;
                if (f & 1) break; // ore wins
            }
        }
        if (best >= 0) {
            out.color = (COLORREF)best;
            out.yTop = bestY;
            out.flags = bestF | 2;
            if (bestY == centerY) out.flags |= 8;
        }
        else {
            out.color = RGB(8, 9, 12);
            out.yTop = centerY;
            out.flags = 2;
        }
    }
}

static void UpdateMinimapData() {
    if (!Java::env) return;

    float px, py, pz, yaw;
    if (!Java::GetPlayerPose(px, py, pz, yaw)) return;

    int centerX = (int)floorf(px);
    int centerZ = (int)floorf(pz);
    int centerY = (int)floorf(py);

    // (Re)detect underground state periodically. A 5-column scan (center +
    // four NESW neighbors) handles ravines and caves with an open ceiling
    // directly above the player. Threshold and Y cap are loose so caves at
    // higher Y (e.g. mountain caves) still count as "underground" for the
    // cave rendering mode.
    static ULONGLONG lastUndergroundCheck = 0;
    ULONGLONG now = GetTickCount64();
    if (!g_stagingValid || now - lastUndergroundCheck > 1500) {
        static const int OX[5] = { 0,  2, -2,  0,  0 };
        static const int OZ[5] = { 0,  0,  0,  2, -2 };
        int bestHits = 0;
        for (int k = 0; k < 5; k++) {
            int hits = 0;
            for (int dy = 2; dy < 18; dy++) {
                uint8_t f;
                int c = Java::GetBlockColorAt(centerX + OX[k], centerY + dy, centerZ + OZ[k], f);
                if (c >= 0) {
                    int r = GetRValue((COLORREF)c), g = GetGValue((COLORREF)c), b = GetBValue((COLORREF)c);
                    if (!(r == 0 && g == 0 && b == 0)) hits++;
                }
            }
            if (hits > bestHits) bestHits = hits;
        }
        g_stagingUnderground = (bestHits >= 3) && (centerY < 80);
        g_stagingCenterY = centerY;
        lastUndergroundCheck = now;
    }

    // Scroll the staging buffer when player moved enough to shift grid origin
    if (g_stagingValid) {
        int dx = centerX - g_stagingCenterX;
        int dz = centerZ - g_stagingCenterZ;
        if (dx != 0 || dz != 0) {
            // Shift samples; areas outside overlap get zeroed and re-sampled later
            static MapSample shifted[TERRAIN_DIM * TERRAIN_DIM];
            memset(shifted, 0, sizeof(shifted));
            for (int z = 0; z < TERRAIN_DIM; z++) {
                int srcZ = z + dz;
                if (srcZ < 0 || srcZ >= TERRAIN_DIM) continue;
                for (int x = 0; x < TERRAIN_DIM; x++) {
                    int srcX = x + dx;
                    if (srcX < 0 || srcX >= TERRAIN_DIM) continue;
                    shifted[z * TERRAIN_DIM + x] = g_stagingSamples[srcZ * TERRAIN_DIM + srcX];
                }
            }
            memcpy(g_stagingSamples, shifted, sizeof(shifted));
            g_stagingCenterX = centerX;
            g_stagingCenterZ = centerZ;
            // Force re-sampling of edge rows first by resetting cursor
            g_stagingRowCursor = 0;
        }
    }
    else {
        // Initial scan in progress: set the center ONCE and preserve
        // g_stagingRowCursor across ticks so the first full pass can
        // actually complete and flip g_stagingValid. Previously the
        // cursor got reset to 0 every tick, so rows 8..127 were never
        // sampled and the minimap was stuck on "Loading...".
        static bool stagingInited = false;
        if (!stagingInited) {
            g_stagingCenterX = centerX;
            g_stagingCenterZ = centerZ;
            g_stagingRowCursor = 0;
            stagingInited = true;
        }
    }

    // Do a slice of rows this tick. Start with the rows closest to the player
    // so the area around the arrow fills in first (feels faster). We walk an
    // "inside-out" order: center row, center-1, center+1, center-2, center+2,
    // etc., then wrap to far edges. This makes the nearby terrain appear
    // almost immediately while the outskirts stream in behind it.
    const int ROWS_PER_TICK = 48;
    int half = TERRAIN_DIM / 2;
    for (int rr = 0; rr < ROWS_PER_TICK; rr++) {
        int step = g_stagingRowCursor;
        int z;
        if (step >= TERRAIN_DIM) { g_stagingRowCursor = 0; step = 0; }
        // 0 -> half, 1 -> half-1, 2 -> half+1, 3 -> half-2, 4 -> half+2 ...
        if (step == 0) z = half;
        else {
            int k = (step + 1) / 2;
            z = (step & 1) ? (half - k) : (half + k);
        }
        if (z < 0 || z >= TERRAIN_DIM) { g_stagingRowCursor++; continue; }

        int bz = centerZ + (z - half);
        for (int x = 0; x < TERRAIN_DIM; x++) {
            int bx = centerX + (x - half);
            SampleOneColumn(bx, bz, centerY, g_stagingUnderground, g_stagingSamples[z * TERRAIN_DIM + x]);
        }
        g_stagingRowCursor++;
        if (g_stagingRowCursor >= TERRAIN_DIM) {
            g_stagingRowCursor = 0;
            g_stagingValid = true; // first full pass completed -> buffer usable
            break;
        }
    }

    // Publish staging buffer into the renderable MapData every tick. We mark
    // it valid as soon as the center row is populated so the player sees a
    // small disc of terrain around themselves immediately, which then grows
    // outward instead of the UI being frozen on "Loading..." for ~0.6s.
    bool partialOK = g_stagingRowCursor >= 2 || g_stagingValid;
    if (g_mapCSReady && partialOK) {
        EnterCriticalSection(&g_mapCS);
        memcpy(g_map.samples, g_stagingSamples, sizeof(g_stagingSamples));
        g_map.centerBlockX = g_stagingCenterX;
        g_map.centerBlockZ = g_stagingCenterZ;
        g_map.playerX = px;
        g_map.playerY = py;
        g_map.playerZ = pz;
        g_map.playerYaw = yaw;
        g_map.underground = g_stagingUnderground;
        g_map.valid = true;
        g_map.lastUpdate = now;
        LeaveCriticalSection(&g_mapCS);
    }
}

