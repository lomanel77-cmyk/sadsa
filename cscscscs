static void DrawTitleBar(HDC mem, int w) {
    // Solid title background
    RECT tR = { 0, 0, w, TITLE_H };
    HBRUSH b = CreateSolidBrush(C_TITLE_BG);
    FillRect(mem, &tR, b);
    DeleteObject(b);

    // Gradient accent bar at bottom
    TRIVERTEX v[2];
    GRADIENT_RECT gr = { 0, 1 };
    v[0].x = 0; v[0].y = TITLE_H - 3;
    v[0].Red = GetRValue(C_ACCENT) << 8;
    v[0].Green = GetGValue(C_ACCENT) << 8;
    v[0].Blue = GetBValue(C_ACCENT) << 8;
    v[0].Alpha = 0xFF00;
    v[1].x = w; v[1].y = TITLE_H;
    v[1].Red = GetRValue(C_ACCENT2) << 8;
    v[1].Green = GetGValue(C_ACCENT2) << 8;
    v[1].Blue = GetBValue(C_ACCENT2) << 8;
    v[1].Alpha = 0xFF00;
    GradientFill(mem, v, 2, &gr, 1, GRADIENT_FILL_RECT_H);

    // Brand mark: colored square + title
    SetBkMode(mem, TRANSPARENT);

    FillRoundRect(mem, 18, (TITLE_H - 22) / 2, 22, 22, 5, C_ACCENT);
    SetTextColor(mem, RGB(10, 14, 22));
    SelectObject(mem, g_fontTiny);
    RECT kR = { 18, (TITLE_H - 22) / 2, 40, (TITLE_H - 22) / 2 + 22 };
    DrawTextA(mem, "K", -1, &kR, DT_CENTER | DT_SINGLELINE | DT_VCENTER);

    SelectObject(mem, g_fontTitle);
    SetTextColor(mem, C_TEXT);
    RECT titleR = { 52, 0, w - 60, TITLE_H };
    DrawTextA(mem, "Karvis Files", -1, &titleR, DT_LEFT | DT_SINGLELINE | DT_VCENTER);

    // Version pill
    SelectObject(mem, g_fontTiny);
    SIZE ts; GetTextExtentPoint32A(mem, "v1", 2, &ts);
    int pillW = ts.cx + 14, pillH = 18;
    int pillX = 52 + 120, pillY = (TITLE_H - pillH) / 2;
    FillRoundRect(mem, pillX, pillY, pillW, pillH, 9, RGB(30, 40, 60));
    SetTextColor(mem, C_ACCENT);
    RECT pillR = { pillX, pillY, pillX + pillW, pillY + pillH };
    DrawTextA(mem, "v1", -1, &pillR, DT_CENTER | DT_SINGLELINE | DT_VCENTER);
}

static void DrawCloseButton(HDC mem, int w) {
    int closeX = w - 40, closeY = 14, closeSz = 26;
    FillRoundRect(mem, closeX, closeY, closeSz, closeSz, 6, RGB(142, 50, 60));
    SetTextColor(mem, C_TEXT);
    SelectObject(mem, g_fontItem);
    RECT closeR = { closeX, closeY, closeX + closeSz, closeY + closeSz };
    SetBkMode(mem, TRANSPARENT);
    DrawTextA(mem, "X", -1, &closeR, DT_CENTER | DT_SINGLELINE | DT_VCENTER);
}

static void DrawSidebar(HDC mem, int w, int h) {
    // Sidebar background (slightly darker than main bg)
    RECT sR = { 0, TITLE_H, SIDEBAR_W, h - FOOTER_H };
    HBRUSH b = CreateSolidBrush(C_SIDEBAR_BG);
    FillRect(mem, &sR, b);
    DeleteObject(b);

    // Right divider line
    HPEN pn = CreatePen(PS_SOLID, 1, C_BORDER);
    HPEN op = (HPEN)SelectObject(mem, pn);
    MoveToEx(mem, SIDEBAR_W - 1, TITLE_H, nullptr);
    LineTo(mem, SIDEBAR_W - 1, h - FOOTER_H);
    SelectObject(mem, op);
    DeleteObject(pn);

    // Tabs
    SetBkMode(mem, TRANSPARENT);
    for (int t = 0; t < 2; t++) {
        int ty = TAB_TOP + t * (TAB_H + 6);
        bool active = (t == g_currentTab);
        bool hover = (t == g_hoverTab && !active);

        if (active) {
            FillRoundRect(mem, 8, ty, SIDEBAR_W - 16, TAB_H, 8, C_TAB_ACTIVE);
            // Left accent stripe
            HBRUSH accBr = CreateSolidBrush(C_ACCENT);
            RECT aR = { 8, ty + 8, 12, ty + TAB_H - 8 };
            FillRect(mem, &aR, accBr);
            DeleteObject(accBr);
        }
        else if (hover) {
            FillRoundRect(mem, 8, ty, SIDEBAR_W - 16, TAB_H, 8, RGB(18, 22, 32));
        }

        SelectObject(mem, g_fontTab);
        SetTextColor(mem, active ? C_TEXT : C_DIM);
        RECT nR = { 20, ty + 8, SIDEBAR_W - 12, ty + 30 };
        DrawTextA(mem, g_tabNames[t], -1, &nR, DT_LEFT | DT_SINGLELINE | DT_TOP);

        SelectObject(mem, g_fontSmall);
        SetTextColor(mem, active ? C_ACCENT : RGB(90, 96, 115));
        RECT sbR = { 20, ty + 30, SIDEBAR_W - 12, ty + TAB_H - 6 };
        DrawTextA(mem, g_tabSubtitles[t], -1, &sbR, DT_LEFT | DT_SINGLELINE | DT_TOP);
    }
}

static void DrawContentItems(HDC mem, int w, int h) {
    const auto& items = g_tabItems[g_currentTab];
    int scroll = g_scrollOffset[g_currentTab];

    // Clip region so scrolling items never bleed into title/footer
    HRGN clip = CreateRectRgn(SIDEBAR_W + 1, TITLE_H, w, h - FOOTER_H);
    SelectClipRgn(mem, clip);

    int baseX = SIDEBAR_W + ITEM_PAD_X;
    int itemWidth = w - SIDEBAR_W - ITEM_PAD_X * 2 - SCROLL_W - 4;
    int itemY = TITLE_H + 14 - scroll;

    SetBkMode(mem, TRANSPARENT);

    for (int i = 0; i < (int)items.size(); i++) {
        // Skip items entirely outside the visible region
        if (itemY + ITEM_H >= TITLE_H && itemY < h - FOOTER_H) {
            const auto& item = items[i];
            bool hover = (i == g_hoverItem);

            FillRoundRect(mem, baseX, itemY, itemWidth, ITEM_H, 10, hover ? C_ITEM_HOVER : C_ITEM_BG);

            // Left accent strip when "lit"
            bool lit = false;
            if (item.type == MenuItem::TOGGLE && item.valuePtr) lit = *((bool*)item.valuePtr);
            if (item.type == MenuItem::CYCLE)  lit = true;
            if (item.type == MenuItem::BUTTON) lit = (item.name == "Change Nick" && g_settings.nickname[0] != '\0');
            if (lit) {
                HBRUSH ab = CreateSolidBrush(C_ACCENT);
                RECT ar = { baseX + 2, itemY + 8, baseX + 5, itemY + ITEM_H - 8 };
                FillRect(mem, &ar, ab);
                DeleteObject(ab);
            }

            // Name
            SetTextColor(mem, C_TEXT);
            SelectObject(mem, g_fontItem);
            RECT nameR = { baseX + 16, itemY + 10, baseX + itemWidth - 150, itemY + 30 };
            DrawTextA(mem, item.name.c_str(), -1, &nameR, DT_LEFT | DT_SINGLELINE | DT_TOP);

            // Description
            SetTextColor(mem, C_DIM);
            SelectObject(mem, g_fontSmall);
            RECT descR = { baseX + 16, itemY + 32, baseX + itemWidth - 150, itemY + ITEM_H - 4 };
            DrawTextA(mem, item.description.c_str(), -1, &descR, DT_LEFT | DT_SINGLELINE | DT_TOP);

            // Control on the right
            if (item.type == MenuItem::TOGGLE) {
                bool on = *((bool*)item.valuePtr);
                int swW = 50, swH = 26;
                int swX = baseX + itemWidth - 14 - swW;
                int swY = itemY + (ITEM_H - swH) / 2;

                FillRoundRect(mem, swX, swY, swW, swH, 13, on ? C_ON : C_OFF);
                int circleX = on ? swX + swW - swH + 3 : swX + 3;
                FillRoundRect(mem, circleX, swY + 3, swH - 6, swH - 6, 10, RGB(250, 252, 255));
            }
            else if (item.type == MenuItem::BUTTON) {
                int btnW = 110, btnH = 32;
                int btnX = baseX + itemWidth - 14 - btnW;
                int btnY = itemY + (ITEM_H - btnH) / 2;

                FillRoundRect(mem, btnX, btnY, btnW, btnH, 8, C_ACCENT);
                SetTextColor(mem, RGB(10, 14, 22));
                SelectObject(mem, g_fontSmall);
                RECT btnR = { btnX, btnY, btnX + btnW, btnY + btnH };

                std::string btnText;
                if (item.name == "Change Nick" && g_settings.nickname[0] != '\0') {
                    btnText = std::string(g_settings.nickname);
                    if (btnText.length() > 12) btnText = btnText.substr(0, 11) + "..";
                }
                else if (item.name == "Change Nick") { btnText = "Set Nick"; }
                else btnText = "Click";
                DrawTextA(mem, btnText.c_str(), -1, &btnR, DT_CENTER | DT_SINGLELINE | DT_VCENTER);
            }
            else if (item.type == MenuItem::CYCLE) {
                int v = CycleGetValue(item);
                std::string label = "?";
                if (v >= 0 && v < (int)item.cycleOptions.size()) label = item.cycleOptions[v];

                int cW = 150, cH = 32;
                int cX = baseX + itemWidth - 14 - cW;
                int cY = itemY + (ITEM_H - cH) / 2;
                FillRoundRect(mem, cX, cY, cW, cH, 8, RGB(30, 36, 52));

                // chevrons
                SelectObject(mem, g_fontItem);
                SetTextColor(mem, C_ACCENT);
                RECT lArrow = { cX + 4, cY, cX + 22, cY + cH };
                DrawTextA(mem, "<", -1, &lArrow, DT_CENTER | DT_SINGLELINE | DT_VCENTER);
                RECT rArrow = { cX + cW - 22, cY, cX + cW - 4, cY + cH };
                DrawTextA(mem, ">", -1, &rArrow, DT_CENTER | DT_SINGLELINE | DT_VCENTER);

                SelectObject(mem, g_fontSmall);
                SetTextColor(mem, C_TEXT);
                RECT lblR = { cX + 22, cY, cX + cW - 22, cY + cH };
                DrawTextA(mem, label.c_str(), -1, &lblR, DT_CENTER | DT_SINGLELINE | DT_VCENTER);
            }
        }
        itemY += ITEM_H + ITEM_GAP;
    }

    SelectClipRgn(mem, nullptr);
    DeleteObject(clip);

    // Scrollbar indicator on right edge of content area
    int totalH = TabContentHeight(g_currentTab);
    int visibleH = CONTENT_H;
    if (totalH > visibleH) {
        int trackX = w - SCROLL_W - 4;
        int trackY = TITLE_H + 8;
        int trackH = h - FOOTER_H - TITLE_H - 16;

        // Track
        HBRUSH tb = CreateSolidBrush(RGB(20, 24, 34));
        RECT tR = { trackX, trackY, trackX + SCROLL_W, trackY + trackH };
        FillRect(mem, &tR, tb);
        DeleteObject(tb);

        // Thumb
        int thumbH = (visibleH * trackH) / totalH;
        if (thumbH < 24) thumbH = 24;
        int thumbY = trackY + ((scroll * (trackH - thumbH)) / (totalH - visibleH));
        FillRoundRect(mem, trackX, thumbY, SCROLL_W, thumbH, SCROLL_W / 2, C_SCROLL);
    }
}

static void DrawFooter(HDC mem, int w, int h) {
    int fy = h - FOOTER_H;

    // Top divider
    HPEN pn = CreatePen(PS_SOLID, 1, C_BORDER);
    HPEN op = (HPEN)SelectObject(mem, pn);
    MoveToEx(mem, 0, fy, nullptr);
    LineTo(mem, w, fy);
    SelectObject(mem, op);
    DeleteObject(pn);

    SetBkMode(mem, TRANSPARENT);

    // Status LED dot (green if running, yellow if initializing)
    bool ok = (strstr(g_debugStatus, "Ready") != nullptr);
    COLORREF dot = ok ? RGB(80, 220, 130) : RGB(230, 190, 60);
    HBRUSH db = CreateSolidBrush(dot);
    int dotX = 18, dotY = fy + FOOTER_H / 2 - 4;
    Ellipse(mem, dotX, dotY, dotX + 8, dotY + 8);
    DeleteObject(db);

    SelectObject(mem, g_fontSmall);
    SetTextColor(mem, C_DIM);
    RECT sR = { dotX + 14, fy, w / 2, h };
    DrawTextA(mem, g_debugStatus, -1, &sR, DT_LEFT | DT_SINGLELINE | DT_VCENTER);

    // Hotkey hint on right
    SetTextColor(mem, RGB(96, 102, 124));
    RECT kR = { w / 2, fy, w - 16, h };
    DrawTextA(mem, "SHIFT+ALT  toggle    DEL  unload    F11  borderless",
        -1, &kR, DT_RIGHT | DT_SINGLELINE | DT_VCENTER);
}

LRESULT CALLBACK GuiWndProc(HWND hWnd, UINT msg, WPARAM wParam, LPARAM lParam) {
    switch (msg) {
    case WM_CREATE:
        SetTimer(hWnd, 1, 300, nullptr);
        return 0;

    case WM_TIMER:
        InvalidateRect(hWnd, nullptr, FALSE);
        return 0;

    case WM_ERASEBKGND:
        return TRUE;

    case WM_PAINT: {
        PAINTSTRUCT ps;
        HDC hdc = BeginPaint(hWnd, &ps);
        RECT cr;
        GetClientRect(hWnd, &cr);
        int w = cr.right, h = cr.bottom;

        if (!g_cachedDC || w != g_cachedW || h != g_cachedH) {
            if (g_cachedBmp) DeleteObject(g_cachedBmp);
            if (g_cachedDC) DeleteDC(g_cachedDC);
            g_cachedDC = CreateCompatibleDC(hdc);
            g_cachedBmp = CreateCompatibleBitmap(hdc, w, h);
            SelectObject(g_cachedDC, g_cachedBmp);
            g_cachedW = w;
            g_cachedH = h;
        }

        HDC mem = g_cachedDC;

        // Background
        HBRUSH bgBr = CreateSolidBrush(C_BG);
        FillRect(mem, &cr, bgBr);
        DeleteObject(bgBr);

        DrawTitleBar(mem, w);
        DrawCloseButton(mem, w);
        DrawSidebar(mem, w, h);

        DrawContentItems(mem, w, h);

        DrawFooter(mem, w, h);

        // Outer rounded border
        HPEN borderPen = CreatePen(PS_SOLID, 1, C_BORDER);
        HPEN oldBP = (HPEN)SelectObject(mem, borderPen);
        HBRUSH oldBB = (HBRUSH)SelectObject(mem, GetStockObject(NULL_BRUSH));
        RoundRect(mem, 0, 0, w, h, 12, 12);
        SelectObject(mem, oldBP);
        SelectObject(mem, oldBB);
        DeleteObject(borderPen);

        BitBlt(hdc, 0, 0, w, h, mem, 0, 0, SRCCOPY);
        EndPaint(hWnd, &ps);
        return 0;
    }

    case WM_LBUTTONDOWN: {
        int mx = GET_X_LPARAM(lParam), my = GET_Y_LPARAM(lParam);
        RECT cr;
        GetClientRect(hWnd, &cr);
        int w = cr.right, h = cr.bottom;

        // Close button
        int closeX = w - 40, closeY = 14, closeSz = 26;
        if (mx >= closeX && mx < closeX + closeSz && my >= closeY && my < closeY + closeSz) {
            ShowWindow(hWnd, SW_HIDE);
            return 0;
        }

        // Title bar drag
        if (my < TITLE_H) {
            g_dragging = true;
            POINT pt; GetCursorPos(&pt);
            RECT wr; GetWindowRect(hWnd, &wr);
            g_dragOffset = { pt.x - wr.left, pt.y - wr.top };
            SetCapture(hWnd);
            return 0;
        }

        // Sidebar tab click
        int tab = HitTestTab(mx, my, w, h);
        if (tab >= 0) {
            if (tab != g_currentTab) {
                g_currentTab = tab;
                g_hoverItem = -1;
                ClampScroll();
                InvalidateRect(hWnd, nullptr, FALSE);
            }
            return 0;
        }

        // Content item click
        int idx = HitTestContentItem(mx, my, w, h);
        if (idx >= 0) {
            auto& item = g_tabItems[g_currentTab][idx];
            int scroll = g_scrollOffset[g_currentTab];
            int itemY = TITLE_H + 14 - scroll + idx * (ITEM_H + ITEM_GAP);
            int baseX = SIDEBAR_W + ITEM_PAD_X;
            int itemWidth = w - SIDEBAR_W - ITEM_PAD_X * 2 - SCROLL_W - 4;

            if (item.type == MenuItem::TOGGLE) {
                bool* p = (bool*)item.valuePtr;
                if (p) *p = !(*p);
            }
            else if (item.type == MenuItem::BUTTON) {
                if (item.name == "Change Nick") {
                    OpenNickDialog((HINSTANCE)GetWindowLongPtrA(hWnd, GWLP_HINSTANCE));
                }
            }
            else if (item.type == MenuItem::CYCLE) {
                int cW = 150, cH = 32;
                int cX = baseX + itemWidth - 14 - cW;
                int cY = itemY + (ITEM_H - cH) / 2;
                if (mx >= cX && mx < cX + cW && my >= cY && my < cY + cH) {
                    bool leftHalf = mx < cX + cW / 2;
                    CycleAdvance(item, leftHalf ? -1 : 1);
                }
                else {
                    CycleAdvance(item, 1);
                }
            }
            InvalidateRect(hWnd, nullptr, FALSE);
        }
        return 0;
    }

    case WM_LBUTTONUP:
        if (g_dragging) {
            g_dragging = false;
            ReleaseCapture();
        }
        return 0;

    case WM_MOUSEMOVE: {
        if (g_dragging) {
            POINT pt; GetCursorPos(&pt);
            SetWindowPos(hWnd, nullptr, pt.x - g_dragOffset.x, pt.y - g_dragOffset.y, 0, 0,
                SWP_NOSIZE | SWP_NOZORDER | SWP_NOACTIVATE);
            return 0;
        }

        int mx = GET_X_LPARAM(lParam), my = GET_Y_LPARAM(lParam);
        RECT cr; GetClientRect(hWnd, &cr);
        int w = cr.right, h = cr.bottom;

        int newTab = HitTestTab(mx, my, w, h);
        int newItem = HitTestContentItem(mx, my, w, h);
        if (newItem < 0) newItem = -1;

        if (newTab != g_hoverTab || newItem != g_hoverItem) {
            g_hoverTab = newTab;
            g_hoverItem = newItem;
            InvalidateRect(hWnd, nullptr, FALSE);
        }

        TRACKMOUSEEVENT tme = { sizeof(tme), TME_LEAVE, hWnd, 0 };
        TrackMouseEvent(&tme);
        return 0;
    }

    case WM_MOUSEWHEEL: {
        short delta = GET_WHEEL_DELTA_WPARAM(wParam);
        // Scroll only when cursor is over content region
        POINT pt; pt.x = GET_X_LPARAM(lParam); pt.y = GET_Y_LPARAM(lParam);
        ScreenToClient(hWnd, &pt);
        RECT cr; GetClientRect(hWnd, &cr);
        int w = cr.right, h = cr.bottom;
        bool inContent = (pt.x >= SIDEBAR_W && pt.x < w && pt.y >= TITLE_H && pt.y < h - FOOTER_H);
        if (inContent) {
            int step = (delta > 0 ? -1 : 1) * 48;
            g_scrollOffset[g_currentTab] += step;
            ClampScroll();
            InvalidateRect(hWnd, nullptr, FALSE);
        }
        return 0;
    }

    case WM_MOUSELEAVE:
        if (g_hoverItem != -1 || g_hoverTab != -1) {
            g_hoverItem = -1;
            g_hoverTab = -1;
            InvalidateRect(hWnd, nullptr, FALSE);
        }
        return 0;

    case WM_MOUSEACTIVATE:
        return MA_NOACTIVATE;

    case WM_SYSCOMMAND:
        if ((wParam & 0xFFF0) == SC_MINIMIZE) {
            ShowWindow(hWnd, SW_HIDE);
            return 0;
        }
        return DefWindowProc(hWnd, msg, wParam, lParam);

    case WM_CLOSE:
        ShowWindow(hWnd, SW_HIDE);
        return 0;

    case WM_DESTROY:
        KillTimer(hWnd, 1);
        if (g_cachedBmp) { DeleteObject(g_cachedBmp); g_cachedBmp = nullptr; }
        if (g_cachedDC) { DeleteDC(g_cachedDC);      g_cachedDC = nullptr; }
        g_cachedW = 0;
        g_cachedH = 0;
        PostQuitMessage(0);
        return 0;
    }

    return DefWindowProc(hWnd, msg, wParam, lParam);
}

bool CreateGuiWindow(HINSTANCE hInst) {
    g_fontTitle = CreateFontA(22, 0, 0, 0, FW_BOLD, FALSE, FALSE, FALSE, DEFAULT_CHARSET, 0, 0, CLEARTYPE_QUALITY, DEFAULT_PITCH | FF_SWISS, "Segoe UI");
    g_fontItem = CreateFontA(15, 0, 0, 0, FW_SEMIBOLD, FALSE, FALSE, FALSE, DEFAULT_CHARSET, 0, 0, CLEARTYPE_QUALITY, DEFAULT_PITCH | FF_SWISS, "Segoe UI");
    g_fontSmall = CreateFontA(12, 0, 0, 0, FW_NORMAL, FALSE, FALSE, FALSE, DEFAULT_CHARSET, 0, 0, CLEARTYPE_QUALITY, DEFAULT_PITCH | FF_SWISS, "Segoe UI");
    g_fontTiny = CreateFontA(11, 0, 0, 0, FW_BOLD, FALSE, FALSE, FALSE, DEFAULT_CHARSET, 0, 0, CLEARTYPE_QUALITY, DEFAULT_PITCH | FF_SWISS, "Segoe UI");

    WNDCLASSEXA wc = {
        sizeof(wc), CS_HREDRAW | CS_VREDRAW, GuiWndProc, 0, 0, hInst, 0,
        LoadCursor(nullptr, IDC_ARROW), CreateSolidBrush(C_BG), 0, "KarvisFilesGui", 0
    };

    if (!RegisterClassExA(&wc)) return false;

    InitMenuItems();

    int screenW = GetSystemMetrics(SM_CXSCREEN);
    int screenH = GetSystemMetrics(SM_CYSCREEN);
    int posX = (screenW - GUI_W) / 2;
    int posY = (screenH - GUI_H) / 2;

    g_hWnd = CreateWindowExA(WS_EX_TOPMOST | WS_EX_TOOLWINDOW | WS_EX_NOACTIVATE,
        "KarvisFilesGui", "Karvis Files v1", WS_POPUP,
        posX, posY, GUI_W, GUI_H, 0, 0, hInst, 0);

    if (!g_hWnd) return false;
    ShowWindow(g_hWnd, SW_SHOWNOACTIVATE);
    UpdateWindow(g_hWnd);
    g_guiVisible = true;
    return true;
}

// ===================== HOOK THREAD =====================
DWORD WINAPI MouseHookThread(LPVOID param) {
    g_mouseHook = SetWindowsHookExA(WH_MOUSE_LL, LowLevelMouseProc, (HINSTANCE)(HMODULE)param, 0);
    g_keyboardHook = SetWindowsHookExA(WH_KEYBOARD_LL, LowLevelKeyboardProc, (HINSTANCE)(HMODULE)param, 0);
    if (!g_mouseHook) return 1;
    MSG msg;
    while (GetMessage(&msg, nullptr, 0, 0) > 0) {
        TranslateMessage(&msg);
        DispatchMessage(&msg);
    }
    if (g_mouseHook) { UnhookWindowsHookEx(g_mouseHook); g_mouseHook = nullptr; }
    if (g_keyboardHook) { UnhookWindowsHookEx(g_keyboardHook); g_keyboardHook = nullptr; }
    return 0;
}

