// ===================== LOGGING =====================
static FILE* g_logFile = nullptr;
static CRITICAL_SECTION g_logCS;
static bool g_logCSInit = false;

static void LogInit() {
    if (g_logFile) return;
    if (!g_logCSInit) { InitializeCriticalSection(&g_logCS); g_logCSInit = true; }
    char path[MAX_PATH];
    GetTempPathA(MAX_PATH, path);
    strcat_s(path, "karvis_debug.log");
    fopen_s(&g_logFile, path, "w");
    if (g_logFile) { fprintf(g_logFile, "=== Karvis Files v1 Log Started ===\n"); fflush(g_logFile); }
}

static void Log(const char* fmt, ...) {
    if (!g_logCSInit) { InitializeCriticalSection(&g_logCS); g_logCSInit = true; }
    if (!g_logFile) LogInit();
    if (!g_logFile) return;
    EnterCriticalSection(&g_logCS);
    SYSTEMTIME st; GetLocalTime(&st);
    fprintf(g_logFile, "[%02d:%02d:%02d.%03d] ", st.wHour, st.wMinute, st.wSecond, st.wMilliseconds);
    va_list args; va_start(args, fmt);
    vfprintf(g_logFile, fmt, args);
    va_end(args);
    fprintf(g_logFile, "\n");
    fflush(g_logFile);
    LeaveCriticalSection(&g_logCS);
}

