    case WM_COMMAND:
        if (LOWORD(wParam) == 103) { DestroyWindow(hwnd); g_nickDialogWnd = nullptr; return 0; }
        if (LOWORD(wParam) == 102) {
            char buf[64] = {};
            GetWindowTextA(g_nickEditCtrl, buf, sizeof(buf));
            int len = (int)strlen(buf);
            if (len < 3) { if (g_nickStatusLabel) SetWindowTextA(g_nickStatusLabel, "Name too short! (min 3)"); return 0; }
            if (len > 16) { if (g_nickStatusLabel) SetWindowTextA(g_nickStatusLabel, "Name too long! (max 16)"); return 0; }
            bool validChars = true;
            for (int i = 0; i < len; i++) {
                char c = buf[i];
                if (!((c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z') || (c >= '0' && c <= '9') || c == '_')) {
                    validChars = false;
                    break;
                }
            }
            if (!validChars) { if (g_nickStatusLabel) SetWindowTextA(g_nickStatusLabel, "Only A-Z, 0-9, _ allowed!"); return 0; }
            strncpy_s(g_settings.nickname, buf, sizeof(g_settings.nickname) - 1);
            strncpy_s(g_pendingNick, buf, sizeof(g_pendingNick) - 1);
            g_nickApplyPending = true;
            if (g_nickStatusLabel) {
                char sm[96];
                snprintf(sm, sizeof(sm), "Applying: %s ...", buf);
                SetWindowTextA(g_nickStatusLabel, sm);
            }
            SetTimer(hwnd, 50, 1500, nullptr);
            return 0;
        }
        break;
    case WM_TIMER:
        if (wParam == 50) { KillTimer(hwnd, 50); DestroyWindow(hwnd); g_nickDialogWnd = nullptr; return 0; }
        break;
    case WM_KEYDOWN:
        if (wParam == VK_RETURN) { SendMessage(hwnd, WM_COMMAND, 102, 0); return 0; }
        if (wParam == VK_ESCAPE) { DestroyWindow(hwnd); g_nickDialogWnd = nullptr; return 0; }
        break;
    case WM_CLOSE:
        DestroyWindow(hwnd);
        g_nickDialogWnd = nullptr;
        return 0;
    case WM_DESTROY:
        if (g_nickDlgBgBrush) { DeleteObject(g_nickDlgBgBrush); g_nickDlgBgBrush = nullptr; }
        if (g_nickDlgEditBgBrush) { DeleteObject(g_nickDlgEditBgBrush); g_nickDlgEditBgBrush = nullptr; }
        if (g_nickDlgFont) { DeleteObject(g_nickDlgFont); g_nickDlgFont = nullptr; }
        if (g_nickDlgFontBig) { DeleteObject(g_nickDlgFontBig); g_nickDlgFontBig = nullptr; }
        g_nickDialogWnd = nullptr;
        g_nickStatusLabel = nullptr;
        return 0;
    }
    return DefWindowProcA(hwnd, msg, wParam, lParam);
}

static void OpenNickDialog(HINSTANCE hInst) {
    if (g_nickDialogWnd && IsWindow(g_nickDialogWnd)) {
        SetForegroundWindow(g_nickDialogWnd);
        SetFocus(g_nickEditCtrl);
        return;
    }
    static bool reg = false;
    if (!reg) {
        WNDCLASSEXA wc = {};
        wc.cbSize = sizeof(wc);
        wc.lpfnWndProc = NickDialogProc;
        wc.hInstance = hInst;
        wc.lpszClassName = "KarvisNickDlg";
        wc.hCursor = LoadCursor(nullptr, IDC_ARROW);
        wc.hbrBackground = CreateSolidBrush(RGB(18, 18, 25));
        RegisterClassExA(&wc);
        reg = true;
    }
    int screenW = GetSystemMetrics(SM_CXSCREEN);
    int screenH = GetSystemMetrics(SM_CYSCREEN);
    int dlgW = 360, dlgH = 250;
    int dlgX = (screenW - dlgW) / 2;
    int dlgY = (screenH - dlgH) / 2;
    g_nickDialogWnd = CreateWindowExA(WS_EX_TOPMOST | WS_EX_TOOLWINDOW, "KarvisNickDlg", "Karvis Files - Nickname",
        WS_POPUP | WS_CAPTION | WS_SYSMENU, dlgX, dlgY, dlgW, dlgH, nullptr, nullptr, hInst, nullptr);
    if (g_nickDialogWnd) {
        ShowWindow(g_nickDialogWnd, SW_SHOW);
        UpdateWindow(g_nickDialogWnd);
        SetForegroundWindow(g_nickDialogWnd);
    }
}

