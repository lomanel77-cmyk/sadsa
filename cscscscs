void FillRoundRect(HDC h, int x, int y, int w, int hh, int r, COLORREF c) {
    HBRUSH b = CreateSolidBrush(c);
    HPEN p = CreatePen(PS_SOLID, 1, c);
    HBRUSH ob = (HBRUSH)SelectObject(h, b);
    HPEN op = (HPEN)SelectObject(h, p);
    RoundRect(h, x, y, x + w, y + hh, r, r);
    SelectObject(h, ob);
    SelectObject(h, op);
    DeleteObject(b);
    DeleteObject(p);
}

static int OpacityValueToIndex(int v) {
    if (v <= 150) return 0;
    if (v <= 205) return 1;
    if (v <= 240) return 2;
    return 3;
}
static int OpacityIndexToValue(int i) {
    static const int tbl[4] = { 127, 190, 229, 255 };
    if (i < 0) i = 0; if (i > 3) i = 3;
    return tbl[i];
}

static int CycleGetValue(const MenuItem& it) {
    if (it.name == "Shape")   return g_settings.mapRound ? 0 : 1;
    if (it.name == "Opacity") return OpacityValueToIndex(g_settings.mapOpacity);
    if (it.valuePtr)          return *((int*)it.valuePtr);
    return 0;
}
static void CycleSetValue(MenuItem& it, int v) {
    if (it.name == "Shape") { g_settings.mapRound = (v == 0); return; }
    if (it.name == "Opacity") { g_settings.mapOpacity = OpacityIndexToValue(v); return; }
    if (it.valuePtr)            *((int*)it.valuePtr) = v;
}
static void CycleAdvance(MenuItem& it, int dir) {
    int v = CycleGetValue(it);
    int lo = it.cycleMin, hi = it.cycleMax;
    v += dir;
    if (v > hi) v = lo;
    if (v < lo) v = hi;
    CycleSetValue(it, v);
}

// Compute total vertical content height for a given tab (for scroll clamping).
static int TabContentHeight(int tab) {
    int n = (int)g_tabItems[tab].size();
    if (n == 0) return 0;
    return 14 /*top pad*/ + n * ITEM_H + (n - 1) * ITEM_GAP + 14 /*bot pad*/;
}
static int MaxScrollForTab(int tab) {
    int h = TabContentHeight(tab) - CONTENT_H;
    return h > 0 ? h : 0;
}

// ---------------------------------------------------------------------------
// Hit testing helpers
//
// Layout:
//   - Title bar:    0 .. TITLE_H
//   - Sidebar:      x 0 .. SIDEBAR_W, y TITLE_H .. (h - FOOTER_H)
//   - Content area: x SIDEBAR_W .. w, y TITLE_H .. (h - FOOTER_H)
//   - Footer:       y (h - FOOTER_H) .. h
// ---------------------------------------------------------------------------

static int HitTestTab(int mx, int my, int w, int h) {
    (void)w; (void)h;
    if (mx < 0 || mx >= SIDEBAR_W) return -1;
    for (int t = 0; t < 2; t++) {
        int ty = TAB_TOP + t * (TAB_H + 6);
        if (my >= ty && my < ty + TAB_H) return t;
    }
    return -1;
}

// Returns the index of the item under (mx,my) accounting for scroll.
// Also returns -2 if the cursor is inside the content area but not on an item.
static int HitTestContentItem(int mx, int my, int w, int h) {
    if (mx < SIDEBAR_W || mx >= w - SCROLL_W - 2) return -1;
    if (my < TITLE_H || my >= h - FOOTER_H) return -1;

    int scroll = g_scrollOffset[g_currentTab];
    int itemY = TITLE_H + 14 - scroll;               // top pad = 14
    const auto& items = g_tabItems[g_currentTab];
    for (int i = 0; i < (int)items.size(); i++) {
        if (my >= itemY && my < itemY + ITEM_H) {
            // Ensure hit is within visible content region
            if (itemY + ITEM_H <= TITLE_H || itemY >= h - FOOTER_H) return -2;
            return i;
        }
        itemY += ITEM_H + ITEM_GAP;
    }
    return -2;
}

static void ClampScroll() {
    int mx = MaxScrollForTab(g_currentTab);
    if (g_scrollOffset[g_currentTab] < 0) g_scrollOffset[g_currentTab] = 0;
    if (g_scrollOffset[g_currentTab] > mx) g_scrollOffset[g_currentTab] = mx;
}

