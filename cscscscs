bool Java::SetNickname(const std::string& nick) {
    if (!env || !field_session || !field_sessionUsername) return false;
    jobject mc = GetMinecraft();
    if (!mc) return false;
    jobject sess = env->GetObjectField(mc, field_session);
    env->DeleteLocalRef(mc);
    if (!sess) return false;

    jstring newName = env->NewStringUTF(nick.c_str());
    if (!newName) { env->DeleteLocalRef(sess); return false; }
    env->SetObjectField(sess, field_sessionUsername, newName);
    env->DeleteLocalRef(newName);
    env->DeleteLocalRef(sess);
    Log("Nickname set to: %s", nick.c_str());
    return true;
}

