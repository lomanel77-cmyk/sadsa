bool Java::Initialize() {
    Log("=== Java::Initialize ===");
    HMODULE jvmDll = nullptr;
    for (int i = 0; i < 60; i++) {
        jvmDll = GetModuleHandleA("jvm.dll");
        if (jvmDll) break;
        Sleep(1000);
    }
    if (!jvmDll) { Log("ERROR: jvm.dll not found"); return false; }

    auto fn = (JNI_GetCreatedJavaVMs_t)GetProcAddress(jvmDll, "JNI_GetCreatedJavaVMs");
    if (!fn) return false;

    jsize cnt = 0;
    if (fn(&jvm, 1, &cnt) != JNI_OK || cnt == 0) return false;
    if (jvm->AttachCurrentThread((void**)&env, nullptr) != JNI_OK) return false;
    attached = true;

    jvm->GetEnv((void**)&jvmti, JVMTI_VERSION_1_2);
    if (!jvmti) return false;

    if (!FindClassLoader()) return false;
    return InitCache();
}

bool Java::FindClassLoader() {
    if (!env || !jvmti) return false;
    jint classCount = 0;
    jclass* classes = nullptr;
    if (jvmti->GetLoadedClasses(&classCount, &classes) != JVMTI_ERROR_NONE) return false;

    bool found = false;
    for (int i = 0; i < classCount; i++) {
        if (!found) {
            char* sig = nullptr;
            jvmti->GetClassSignature(classes[i], &sig, nullptr);
            if (sig) {
                std::string s(sig);
                jvmti->Deallocate((unsigned char*)sig);
                if (s == "Lnet/minecraft/client/Minecraft;" || s == "Lave;") {
                    jclass cc = env->GetObjectClass(classes[i]);
                    if (cc) {
                        jmethodID getCL = env->GetMethodID(cc, "getClassLoader", "()Ljava/lang/ClassLoader;");
                        if (env->ExceptionCheck()) env->ExceptionClear();
                        if (getCL) {
                            jobject cl = env->CallObjectMethod(classes[i], getCL);
                            if (env->ExceptionCheck()) env->ExceptionClear();
                            if (cl) {
                                cachedClassLoader = env->NewGlobalRef(cl);
                                env->DeleteLocalRef(cl);
                                found = true;
                            }
                        }
                        env->DeleteLocalRef(cc);
                    }
                }
            }
        }
        env->DeleteLocalRef(classes[i]);
    }
    jvmti->Deallocate((unsigned char*)classes);
    return found;
}

jclass Java::FindClass(const char* name) {
    if (!env) return nullptr;
    jclass result = env->FindClass(name);
    if (result && !env->ExceptionCheck()) return result;
    env->ExceptionClear();

    if (cachedClassLoader) {
        std::string cn(name);
        for (auto& c : cn) if (c == '/') c = '.';
        jclass cc = env->GetObjectClass(cachedClassLoader);
        if (!cc) return nullptr;
        jmethodID lc = env->GetMethodID(cc, "loadClass", "(Ljava/lang/String;)Ljava/lang/Class;");
        if (env->ExceptionCheck()) env->ExceptionClear();
        if (lc) {
            jstring jn = env->NewStringUTF(cn.c_str());
            if (jn) {
                result = (jclass)env->CallObjectMethod(cachedClassLoader, lc, jn);
                env->DeleteLocalRef(jn);
                if (result && !env->ExceptionCheck()) {
                    env->DeleteLocalRef(cc);
                    return result;
                }
                env->ExceptionClear();
                if (result) { env->DeleteLocalRef(result); result = nullptr; }
            }
        }
        env->DeleteLocalRef(cc);
    }
    return nullptr;
}

